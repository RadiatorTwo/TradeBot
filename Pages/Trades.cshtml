@page
@model ClaudeTradingBot.Pages.TradesModel
@{
    ViewData["Title"] = "Trade-Historie";
}

<h2 style="margin-bottom: 24px;">Trade-Historie</h2>

<!-- Filter -->
<form method="get" class="filter-bar">
    <div class="filter-group">
        <label>Von</label>
        <input type="date" name="From" value="@Model.From?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="filter-group">
        <label>Bis</label>
        <input type="date" name="To" value="@Model.To?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="filter-group">
        <label>Symbol</label>
        <select name="Symbol">
            <option value="">Alle</option>
            @foreach (var s in Model.AvailableSymbols)
            {
                <option value="@s" selected="@(Model.Symbol == s)">@s</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Status</label>
        <select name="Status">
            <option value="">Alle</option>
            <option value="Executed" selected="@(Model.Status == "Executed")">Ausgeführt</option>
            <option value="Failed" selected="@(Model.Status == "Failed")">Fehlgeschlagen</option>
            <option value="Rejected" selected="@(Model.Status == "Rejected")">Abgelehnt</option>
            <option value="Pending" selected="@(Model.Status == "Pending")">Ausstehend</option>
            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Abgebrochen</option>
        </select>
    </div>
    <div class="filter-group" style="justify-content: end;">
        <button type="submit" class="btn btn-primary">Filtern</button>
    </div>
    <div class="filter-group" style="justify-content: end;">
        <a href="/api/trades/export?from=@Model.From?.ToString("yyyy-MM-dd")&to=@Model.To?.ToString("yyyy-MM-dd")&symbol=@Model.Symbol&status=@Model.Status"
           class="btn btn-outline">CSV Export</a>
    </div>
</form>

@if (Model.Trades.Any())
{
    <table>
        <thead>
            <tr>
                <th>Zeit</th><th>Symbol</th><th>Aktion</th>
                <th>Menge</th><th>Preis</th><th>Confidence</th>
                <th>Status</th><th>Begrundung</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Trades)
            {
                <tr>
                    <td style="font-size:0.75rem;color:var(--muted)">@t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td><strong>@t.Symbol</strong></td>
                    <td class="@(t.Action == TradeAction.Buy ? "pnl-positive" : "pnl-negative")">
                        @t.Action.ToString().ToUpper()
                    </td>
                    <td>@t.Quantity.ToString("F2")</td>
                    <td>$@t.Price.ToString("F4")</td>
                    <td>@t.ClaudeConfidence.ToString("P0")</td>
                    <td>
                        @switch (t.Status)
                        {
                            case TradeStatus.Executed:
                                <span class="badge badge-green">Ausgeführt</span>
                                break;
                            case TradeStatus.Failed:
                                <span class="badge badge-red" title="@t.ErrorMessage">Fehlgeschlagen</span>
                                break;
                            case TradeStatus.Rejected:
                                <span class="badge badge-orange" title="@t.ErrorMessage">Abgelehnt</span>
                                break;
                            case TradeStatus.Pending:
                                <span class="badge badge-yellow">Ausstehend</span>
                                break;
                            case TradeStatus.Cancelled:
                                <span class="badge badge-yellow">Abgebrochen</span>
                                break;
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(t.ErrorMessage))
                        {
                            <div style="color:#f97316;font-size:0.8rem;margin-bottom:4px">@t.ErrorMessage</div>
                        }
                        <div class="reasoning-toggle" onclick="this.nextElementSibling.classList.toggle('open')">
                            @(t.ClaudeReasoning.Length > 60 ? t.ClaudeReasoning[..60] + "..." : t.ClaudeReasoning)
                        </div>
                        <div class="reasoning-full">@t.ClaudeReasoning</div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="empty-state">Keine Trades gefunden</div>
}
