{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "ClaudeTradingBot": "Debug",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/trading-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "restrictedToMinimumLevel": "Debug"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "TradingDb": "Data Source=trading.db"
  },
  "Llm": {
    "Provider": "OpenAICompatible"
  },
  "Anthropic": {
    "ApiKey": "",
    "Model": "claude-sonnet-4-20250514",
    "MaxTokens": 2048
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-2.0-flash-lite",
    "MaxTokens": 2048
  },
  "OpenAICompatible": {
    "BaseUrl": "http://localhost:11434/v1/",
    "ApiKey": "",
    "Model": "qwen2.5:32b",
    "MaxTokens": 2048
  },
  "Telegram": {
    "BotToken": "",
    "ChatId": "",
    "NotifyOnTrade": true,
    "NotifyOnAlert": true
  },
  "EconomicCalendar": {
    "ApiUrl": "",
    "BufferMinutesBefore": 30,
    "BufferMinutesAfter": 15
  },
  "News": {
    "Enabled": false,
    "FinnhubApiKey": "",
    "MaxHeadlinesPerSymbol": 5,
    "RefreshIntervalMinutes": 60
  },
  "Report": {
    "Enabled": false,
    "DailyEnabled": true,
    "WeeklyEnabled": true,
    "ReportTimeUtc": "22:00:00"
  },
  "AllowedHosts": "*"
}
