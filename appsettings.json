{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread",
      "Serilog.Formatting.Compact"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "ClaudeTradingBot": "Debug",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "ClaudeTradingBot"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Information",
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}  {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/trading-.json",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "restrictedToMinimumLevel": "Debug",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "TradingDb": "Data Source=trading.db"
  },
  "Llm": {
    "Provider": "OpenAICompatible"
  },
  "Anthropic": {
    "ApiKey": "",
    "Model": "claude-sonnet-4-20250514",
    "MaxTokens": 2048
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-2.0-flash-lite",
    "MaxTokens": 2048
  },
  "OpenAICompatible": {
    "BaseUrl": "http://localhost:11434/v1/",
    "ApiKey": "",
    "Model": "qwen2.5:32b",
    "MaxTokens": 2048
  },
  "Telegram": {
    "BotToken": "",
    "ChatId": "",
    "NotifyOnTrade": true,
    "NotifyOnAlert": true
  },
  "EconomicCalendar": {
    "ApiUrl": "",
    "BufferMinutesBefore": 30,
    "BufferMinutesAfter": 15
  },
  "News": {
    "Enabled": false,
    "FinnhubApiKey": "",
    "MaxHeadlinesPerSymbol": 5,
    "RefreshIntervalMinutes": 60
  },
  "Report": {
    "Enabled": false,
    "DailyEnabled": true,
    "WeeklyEnabled": true,
    "ReportTimeUtc": "22:00:00"
  },
  "AllowedHosts": "*"
}
