{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/trading-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "ConnectionStrings": {
    "TradingDb": "Data Source=trading.db"
  },
  "Llm": {
    "Provider": "OpenAICompatible"
  },
  "Anthropic": {
    "ApiKey": "",
    "Model": "claude-sonnet-4-20250514",
    "MaxTokens": 2048
  },
  "Gemini": {
    "ApiKey": "",
    "Model": "gemini-2.0-flash-lite",
    "MaxTokens": 2048
  },
  "OpenAICompatible": {
    "BaseUrl": "http://localhost:11434/v1/",
    "ApiKey": "",
    "Model": "qwen2.5:32b",
    "MaxTokens": 2048
  },
  "TradeLocker": {
    "BaseUrl": "https://demo.tradelocker.com/backend-api",
    "Email": "",
    "Password": "",
    "Server": "",
    "AccountId": null
  },
  "RiskManagement": {
    "MinConfidence": 0.65,
    "MaxPositionSizePercent": 10.0,
    "MaxDailyLossPercent": 3.0,
    "StopLossPercent": 5.0,
    "MaxOpenPositions": 10,
    "TradingIntervalMinutes": 15,
    "KillSwitchEnabled": true,
    "MaxDailyLossAbsolute": 500.0
  },
  "TradingStrategy": {
    "WatchList": [ "EURUSD", "GBPUSD", "USDJPY", "XAUUSD", "US100" ],
    "AnalysisPromptTemplate": "Du bist ein erfahrener quantitativer Analyst. Analysiere die folgenden Marktdaten und gib eine klare Handelsempfehlung. Antworte NUR als JSON."
  },
  "AllowedHosts": "*"
}
