@page "/change-password"
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<RadzenCard Style="max-width: 480px; margin: 80px auto;">
    <RadzenText TextStyle="TextStyle.H5" Style="margin-bottom: 16px;">Passwort aendern</RadzenText>

    @if (_mustChange)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Style="margin-bottom: 16px;">
            Sie muessen Ihr Passwort aendern, bevor Sie fortfahren koennen.
        </RadzenAlert>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Style="margin-bottom: 16px;">
            @_error
        </RadzenAlert>
    }

    @if (!string.IsNullOrEmpty(_success))
    {
        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Style="margin-bottom: 16px;">
            @_success
        </RadzenAlert>
    }

    <EditForm Model="_model" OnValidSubmit="HandleSubmit" FormName="changePassword">
        @if (!_mustChange)
        {
            <div style="margin-bottom: 12px;">
                <RadzenLabel Text="Aktuelles Passwort" />
                <RadzenPassword @bind-Value="_model.CurrentPassword" Style="width: 100%;" />
            </div>
        }

        <div style="margin-bottom: 12px;">
            <RadzenLabel Text="Neues Passwort" />
            <RadzenPassword @bind-Value="_model.NewPassword" Style="width: 100%;" />
        </div>

        <div style="margin-bottom: 16px;">
            <RadzenLabel Text="Neues Passwort bestaetigen" />
            <RadzenPassword @bind-Value="_model.ConfirmPassword" Style="width: 100%;" />
        </div>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
            <RadzenButton Text="Passwort aendern" ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary" />
            @if (!_mustChange)
            {
                <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="@(() => Navigation.NavigateTo("/"))" />
            }
        </RadzenStack>
    </EditForm>
</RadzenCard>

@code {
    private ChangePasswordModel _model = new();
    private bool _mustChange;
    private int _userId;
    private string? _error;
    private string? _success;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (idClaim is null || !int.TryParse(idClaim, out _userId))
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var appUser = await AuthService.GetUserByIdAsync(_userId);
        _mustChange = appUser?.MustChangePassword ?? false;
    }

    private async Task HandleSubmit()
    {
        _error = null;
        _success = null;

        if (string.IsNullOrWhiteSpace(_model.NewPassword) || _model.NewPassword.Length < 8)
        {
            _error = "Das neue Passwort muss mindestens 8 Zeichen lang sein.";
            return;
        }

        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _error = "Die Passwoerter stimmen nicht ueberein.";
            return;
        }

        if (!_mustChange)
        {
            var validUser = await AuthService.ValidateCredentialsAsync(
                (await AuthStateProvider.GetAuthenticationStateAsync()).User.Identity?.Name ?? "",
                _model.CurrentPassword ?? "");

            if (validUser is null)
            {
                _error = "Das aktuelle Passwort ist falsch.";
                return;
            }
        }

        try
        {
            await AuthService.ChangePasswordAsync(_userId, _model.NewPassword);
            _success = "Passwort erfolgreich geaendert. Sie werden weitergeleitet...";
            _model = new();
            StateHasChanged();
            await Task.Delay(1500);
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private class ChangePasswordModel
    {
        public string? CurrentPassword { get; set; }
        public string? NewPassword { get; set; }
        public string? ConfirmPassword { get; set; }
    }
}
