@page "/trades"
@using ClaudeTradingBot.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@attribute [Authorize]
@inject IDbContextFactory<TradingDbContext> DbFactory

<PageTitle>Trade-Historie - Claude Trading Bot</PageTitle>

<h2 style="margin-bottom: 24px;">Trade-Historie</h2>

<!-- Filter -->
<RadzenStack Orientation="Orientation.Horizontal" Gap="12px" Style="margin-bottom: 24px;" Wrap="FlexWrap.Wrap" AlignItems="AlignItems.End">
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Von" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDatePicker @bind-Value="FilterFrom" DateFormat="dd.MM.yyyy" />
    </RadzenStack>
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Bis" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDatePicker @bind-Value="FilterTo" DateFormat="dd.MM.yyyy" />
    </RadzenStack>
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Symbol" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDropDown @bind-Value="FilterSymbol" Data="_symbolOptions" TextProperty="Text" ValueProperty="Value" Style="min-width: 140px;" />
    </RadzenStack>
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Status" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDropDown @bind-Value="FilterStatus" Data="_statusOptions" TextProperty="Text" ValueProperty="Value" Style="min-width: 140px;" />
    </RadzenStack>
    <RadzenButton Text="Filtern" ButtonStyle="ButtonStyle.Primary" Click="@ApplyFilter" />
    <RadzenButton Text="CSV Export" Variant="Variant.Outlined" Click="@(() => Navigation.NavigateTo(CsvExportUrl))" />
</RadzenStack>

@if (_trades.Any())
{
    <RadzenDataGrid Data="@_trades" TItem="Trade" Density="Density.Compact" AllowSorting="true"
                    AllowPaging="true" PageSize="50" PagerHorizontalAlign="HorizontalAlign.Center"
                    ShowPagingSummary="true" PagingSummaryFormat="Seite {0} von {1} ({2} Trades)">
        <Columns>
            <RadzenDataGridColumn TItem="Trade" Property="CreatedAt" Title="Zeit" Width="150px">
                <Template Context="t">
                    <span style="font-size:0.75rem;color:var(--muted)">@t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Symbol" Title="Symbol" Width="100px">
                <Template Context="t"><strong>@t.Symbol</strong></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Action" Title="Aktion" Width="80px">
                <Template Context="t">
                    <span class="@(t.Action == TradeAction.Buy ? "pnl-positive" : "pnl-negative")">@t.Action.ToString().ToUpper()</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="SetupType" Title="Setup" Width="100px">
                <Template Context="t"><span style="font-size:0.8rem;">@(t.SetupType ?? "—")</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Quantity" Title="Menge" Width="80px">
                <Template Context="t">@t.Quantity.ToString("F2")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Price" Title="Preis" Width="100px">
                <Template Context="t">$@t.Price.ToString("F4")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="RealizedPnL" Title="PnL" Width="100px">
                <Template Context="t">
                    @if (t.RealizedPnL.HasValue)
                    {
                        <span style="color: @(t.RealizedPnL >= 0 ? "var(--rz-success)" : "var(--rz-danger)");">
                            @t.RealizedPnL.Value.ToString("+0.00;-0.00")
                        </span>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="ClaudeConfidence" Title="Confidence" Width="90px">
                <Template Context="t">@t.ClaudeConfidence.ToString("P0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Title="Status" Width="120px" Sortable="false">
                <Template Context="t"><TradeStatusBadge Status="t.Status" ErrorMessage="@t.ErrorMessage" /></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Title="Begruendung" Sortable="false">
                <Template Context="t"><ReasoningCell ErrorMessage="@t.ErrorMessage" Reasoning="@t.ClaudeReasoning" /></Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}
else
{
    <div class="empty-state">Keine Trades gefunden</div>
}

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private DateTime? FilterFrom { get; set; }
    private DateTime? FilterTo { get; set; }
    private string FilterSymbol { get; set; } = string.Empty;
    private string FilterStatus { get; set; } = string.Empty;

    private List<Trade> _trades = new();

    private record DropDownItem(string Text, string Value);

    private List<DropDownItem> _symbolOptions = new() { new("Alle", "") };
    private List<DropDownItem> _statusOptions = new()
    {
        new("Alle", ""),
        new("Ausgefuehrt", "Executed"),
        new("Fehlgeschlagen", "Failed"),
        new("Abgelehnt", "Rejected"),
        new("Ausstehend", "Pending"),
        new("Abgebrochen", "Cancelled")
    };

    private string CsvExportUrl =>
        $"/api/trades/export?from={FilterFrom?.ToString("yyyy-MM-dd")}&to={FilterTo?.ToString("yyyy-MM-dd")}&symbol={FilterSymbol}&status={FilterStatus}";

    protected override async Task OnInitializedAsync()
    {
        await LoadSymbols();
        await ApplyFilter();
    }

    private async Task LoadSymbols()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var symbols = await db.Trades
            .Select(t => t.Symbol)
            .Distinct()
            .OrderBy(s => s)
            .ToListAsync();

        _symbolOptions = new List<DropDownItem> { new("Alle", "") };
        _symbolOptions.AddRange(symbols.Select(s => new DropDownItem(s, s)));
    }

    private async Task ApplyFilter()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Trades.AsQueryable();

        if (FilterFrom.HasValue)
            query = query.Where(t => t.CreatedAt >= FilterFrom.Value);

        if (FilterTo.HasValue)
            query = query.Where(t => t.CreatedAt <= FilterTo.Value.Date.AddDays(1));

        if (!string.IsNullOrEmpty(FilterSymbol))
            query = query.Where(t => t.Symbol == FilterSymbol);

        if (!string.IsNullOrEmpty(FilterStatus) && Enum.TryParse<TradeStatus>(FilterStatus, out var status))
            query = query.Where(t => t.Status == status);

        _trades = await query
            .OrderByDescending(t => t.CreatedAt)
            .Take(2000)
            .ToListAsync();
    }
}
