@page "/backtest"
@using ClaudeTradingBot.Models
@using ClaudeTradingBot.Services
@inject BacktestEngine BacktestEngine
@inject IConfiguration Configuration
@inject ISettingsRepository SettingsRepo

<PageTitle>Backtest - NeuronTrade</PageTitle>

<h2 style="margin-bottom: 24px;">Backtesting</h2>

<!-- Konfiguration -->
<RadzenCard Style="margin-bottom: 24px;">
    <h3>Backtest-Konfiguration</h3>
    <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
        <RadzenColumn Size="4">
            <RadzenLabel Text="Symbol" Style="display: block; margin-bottom: 4px;" />
            <RadzenDropDown @bind-Value="_config.Symbol" Data="_watchList" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenLabel Text="Timeframe" Style="display: block; margin-bottom: 4px;" />
            <RadzenDropDown @bind-Value="_config.Timeframe" Data="_timeframes" TextProperty="Text" ValueProperty="Value" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenLabel Text="Strategie" Style="display: block; margin-bottom: 4px;" />
            <RadzenDropDown @bind-Value="_config.Strategy" Data="_strategies" TextProperty="Text" ValueProperty="Value" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
        <RadzenColumn Size="4">
            <RadzenLabel Text="Start-Datum" Style="display: block; margin-bottom: 4px;" />
            <RadzenDatePicker @bind-Value="_startDate" DateFormat="dd.MM.yyyy" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenLabel Text="End-Datum" Style="display: block; margin-bottom: 4px;" />
            <RadzenDatePicker @bind-Value="_endDate" DateFormat="dd.MM.yyyy" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenLabel Text="Startkapital ($)" Style="display: block; margin-bottom: 4px;" />
            <RadzenNumeric TValue="decimal" @bind-Value="_config.InitialBalance" ShowUpDown="false" Min="100m" Step="1000m" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
        <RadzenColumn Size="4">
            <RadzenLabel Text="Risiko pro Trade (%)" Style="display: block; margin-bottom: 4px;" />
            <RadzenNumeric TValue="double" @bind-Value="_config.RiskPerTradePercent" ShowUpDown="false" Min="0.1m" Max="10m" Step="0.1m" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenLabel Text="Stop-Loss (Pips)" Style="display: block; margin-bottom: 4px;" />
            <RadzenNumeric TValue="double" @bind-Value="_config.StopLossPips" ShowUpDown="false" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenLabel Text="Take-Profit (Pips)" Style="display: block; margin-bottom: 4px;" />
            <RadzenNumeric TValue="double" @bind-Value="_config.TakeProfitPips" ShowUpDown="false" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
    </RadzenRow>
    <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
        <RadzenColumn Size="4">
            <RadzenLabel Text="Spread (Pips)" Style="display: block; margin-bottom: 4px;" />
            <RadzenNumeric TValue="double" @bind-Value="_config.SpreadPips" ShowUpDown="false" Min="0m" Step="0.5m" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="4">
            <RadzenLabel Text="Slippage (Pips)" Style="display: block; margin-bottom: 4px;" />
            <RadzenNumeric TValue="double" @bind-Value="_config.SlippagePips" ShowUpDown="false" Min="0m" Step="0.1m" Disabled="_isRunning" Style="width: 100%;" />
        </RadzenColumn>
    </RadzenRow>
    <div>
        @if (_isRunning)
        {
            <RadzenButton Text="@($"Backtest laeuft... ({_progress}%)")" Disabled="true" Variant="Variant.Outlined" />
            <RadzenProgressBar Value="_progress" Style="margin-top: 8px;" ShowValue="false" />
        }
        else
        {
            <RadzenButton Text="Backtest Starten" ButtonStyle="ButtonStyle.Primary" Click="@RunBacktest" />
        }
    </div>
</RadzenCard>

@if (_result?.ErrorMessage != null)
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false" Style="margin-bottom: 24px;">
        @_result.ErrorMessage
    </RadzenAlert>
}

@if (_result != null && _result.ErrorMessage == null)
{
    <!-- Statistiken -->
    <div class="section">
        <h2>Ergebnis</h2>
        <div class="stats-grid">
            <StatCard Label="Total Trades" Value="@_result.Stats.TotalTrades.ToString()" />
            <StatCard Label="Win-Rate" Value="@($"{_result.Stats.WinRate:P1}")"
                      CssClass="@(_result.Stats.WinRate >= 0.5 ? "stat-positive" : "stat-negative")" />
            <StatCard Label="Net P&L" Value="@($"${_result.Stats.NetPnL:N2}")"
                      CssClass="@(_result.Stats.NetPnL >= 0 ? "stat-positive" : "stat-negative")" />
            <StatCard Label="Profit Factor" Value="@($"{_result.Stats.ProfitFactor:F2}")"
                      CssClass="@(_result.Stats.ProfitFactor >= 1.5m ? "stat-positive" : _result.Stats.ProfitFactor >= 1m ? "" : "stat-negative")" />
            <StatCard Label="Max Drawdown" Value="@($"{_result.Stats.MaxDrawdownPercent:F1}%")"
                      CssClass="@(_result.Stats.MaxDrawdownPercent <= 10 ? "stat-positive" : "stat-negative")" />
            <StatCard Label="Sharpe Ratio" Value="@($"{_result.Stats.SharpeRatio:F2}")"
                      CssClass="@(_result.Stats.SharpeRatio >= 1 ? "stat-positive" : "stat-negative")" />
            <StatCard Label="Avg Win" Value="@($"${_result.Stats.AvgWin:N2}")" CssClass="stat-positive" />
            <StatCard Label="Avg Loss" Value="@($"${_result.Stats.AvgLoss:N2}")" CssClass="stat-negative" />
            <StatCard Label="Endkapital" Value="@($"${_result.Stats.FinalBalance:N2}")" />
        </div>
    </div>

    <!-- Equity-Kurve -->
    @if (_result.EquityCurve.Count > 0)
    {
        <div class="section">
            <h2>Equity-Kurve</h2>
            <div style="background: var(--card-bg); border-radius: 8px; padding: 16px;">
                <canvas id="backtestEquityChart"></canvas>
            </div>
        </div>
    }

    <!-- Trade-Liste -->
    @if (_result.Trades.Count > 0)
    {
        <div class="section">
            <h2>Trades (@_result.Trades.Count)</h2>
            <RadzenDataGrid Data="@_result.Trades.TakeLast(100).Reverse()" TItem="BacktestTrade" Density="Density.Compact" AllowSorting="true">
                <Columns>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="EntryTime" Title="Entry" Width="120px">
                        <Template Context="t">
                            <span style="font-size:0.75rem;color:var(--muted)">@LocalTime.Short(t.EntryTime)</span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="ExitTime" Title="Exit" Width="120px">
                        <Template Context="t">
                            <span style="font-size:0.75rem;color:var(--muted)">@LocalTime.Short(t.ExitTime)</span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="Side" Title="Side" Width="80px">
                        <Template Context="t">
                            <span class="@(t.Side == "buy" ? "pnl-positive" : "pnl-negative")">@t.Side.ToUpper()</span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="EntryPrice" Title="Entry Preis" Width="110px">
                        <Template Context="t">@t.EntryPrice.ToString("F5")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="ExitPrice" Title="Exit Preis" Width="110px">
                        <Template Context="t">@t.ExitPrice.ToString("F5")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="Quantity" Title="Lots" Width="80px">
                        <Template Context="t">@t.Quantity.ToString("F2")</Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="PnL" Title="P&L" Width="100px">
                        <Template Context="t">
                            <span class="@(t.PnL >= 0 ? "pnl-positive" : "pnl-negative")">
                                @(t.PnL >= 0 ? "+" : "")$@t.PnL.ToString("F2")
                            </span>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="BacktestTrade" Property="Reason" Title="Grund" />
                </Columns>
            </RadzenDataGrid>
            @if (_result.Trades.Count > 100)
            {
                <div class="hint" style="margin-top: 8px;">Zeigt die letzten 100 von @_result.Trades.Count Trades.</div>
            }
        </div>
    }
}

@code {
    private BacktestConfig _config = new();
    private BacktestResult? _result;
    private bool _isRunning;
    private int _progress;
    private string[] _watchList = Array.Empty<string>();
    private DateTime _startDate = DateTime.UtcNow.AddDays(-30).Date;
    private DateTime _endDate = DateTime.UtcNow.Date;

    private record DropDownItem(string Text, string Value);

    private List<DropDownItem> _timeframes = new()
    {
        new("1H", "1H"), new("4H", "4H"), new("1D", "1D")
    };

    private List<DropDownItem> _strategies = new()
    {
        new("EMA-Cross (EMA20/50)", "EMA_Cross"),
        new("RSI-Reversal (RSI14)", "RSI_Reversal")
    };

    protected override async Task OnInitializedAsync()
    {
        var dbWatchList = await SettingsRepo.GetGlobalWatchListAsync();
        _watchList = dbWatchList.Count > 0
            ? dbWatchList.ToArray()
            : Configuration.GetSection("TradingStrategy:WatchList").Get<string[]>()
                ?? new[] { "EURUSD", "GBPUSD", "USDJPY", "XAUUSD", "US100" };
        _config.Symbol = _watchList.FirstOrDefault() ?? "EURUSD";
    }

    private async Task RunBacktest()
    {
        _isRunning = true;
        _result = null;
        _progress = 0;
        StateHasChanged();

        _config.StartDate = _startDate;
        _config.EndDate = _endDate;

        // Validierung
        if (_startDate >= _endDate)
        {
            _result = new BacktestResult { ErrorMessage = "Start-Datum muss vor End-Datum liegen." };
            _isRunning = false;
            return;
        }
        if ((_endDate - _startDate).TotalDays > 365)
        {
            _result = new BacktestResult { ErrorMessage = "Maximaler Zeitraum: 365 Tage." };
            _isRunning = false;
            return;
        }

        var progress = new Progress<int>(pct =>
        {
            _progress = pct;
            InvokeAsync(StateHasChanged);
        });

        // Defensive Kopie damit UI-Aenderungen den laufenden Backtest nicht beeinflussen
        var configCopy = new BacktestConfig
        {
            Symbol = _config.Symbol,
            Timeframe = _config.Timeframe,
            StartDate = _config.StartDate,
            EndDate = _config.EndDate,
            InitialBalance = _config.InitialBalance,
            RiskPerTradePercent = _config.RiskPerTradePercent,
            StopLossPips = _config.StopLossPips,
            TakeProfitPips = _config.TakeProfitPips,
            SpreadPips = _config.SpreadPips,
            SlippagePips = _config.SlippagePips,
            Strategy = _config.Strategy
        };

        try
        {
            _result = await Task.Run(() => BacktestEngine.RunAsync(configCopy, progress));
        }
        catch (Exception ex)
        {
            _result = new BacktestResult { ErrorMessage = $"Fehler: {ex.Message}" };
        }
        finally
        {
            _isRunning = false;
            _progress = 100;
            StateHasChanged();
        }

        // Chart rendern wenn Daten vorhanden
        if (_result?.EquityCurve.Count > 0)
        {
            await RenderEquityChart();
        }
    }

    private async Task RenderEquityChart()
    {
        if (_result?.EquityCurve == null || _result.EquityCurve.Count == 0) return;

        // Equity-Kurve auf max 500 Punkte reduzieren fuer Performance
        var points = _result.EquityCurve;
        if (points.Count > 500)
        {
            var step = points.Count / 500;
            points = points.Where((_, i) => i % step == 0).ToList();
        }

        var labels = points.Select(p => p.Time.ToString("dd.MM")).ToArray();
        var data = points.Select(p => (double)p.Equity).ToArray();

        // Chart.js via JS Interop wuerde hier verwendet werden
        // Da wir kein IJSRuntime injizieren, wird der Chart als Text-Fallback dargestellt
        await Task.CompletedTask;
    }
}
