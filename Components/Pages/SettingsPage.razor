@page "/settings"
@using ClaudeTradingBot.Data
@using ClaudeTradingBot.Models
@using ClaudeTradingBot.Services
@using Microsoft.EntityFrameworkCore
@inject ISettingsRepository SettingsRepo
@inject AccountManager AccountMgr
@inject IConfiguration Configuration
@inject IDbContextFactory<TradingDbContext> DbFactory
@inject DialogService DialogService

<PageTitle>Einstellungen - NeuronTrade</PageTitle>

<h2 style="margin-bottom: 24px;">Globale Einstellungen</h2>

<RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false" Style="margin-bottom: 24px;">
    Hier werden globale Einstellungen verwaltet, die fuer alle Accounts gelten.
    Account-spezifische Einstellungen (Risiko, Intervall, Paper-Trading) werden unter <a href="/accounts">Accounts</a> pro Account konfiguriert.
</RadzenAlert>

@if (_saveSuccess)
{
    <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="true" Style="margin-bottom: 24px;">
        Einstellungen erfolgreich gespeichert.
    </RadzenAlert>
}

@if (_errors.Any())
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false" Style="margin-bottom: 24px;">
        <strong>Validierungsfehler:</strong>
        <ul style="margin: 8px 0 0 16px; list-style: disc;">
            @foreach (var error in _errors)
            {
                <li>@error</li>
            }
        </ul>
    </RadzenAlert>
}

<EditForm Model="this" OnValidSubmit="SaveSettings" FormName="settings">
    <!-- Watchlist -->
    <RadzenCard Style="margin-bottom: 24px;">
        <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">Watchlist</h3>
        <RadzenLabel Text="Symbole (komma-separiert)" Style="display: block; margin-bottom: 4px;" />
        <RadzenTextArea @bind-Value="WatchList" Rows="3" Style="width: 100%;" />
        <div class="hint" style="margin-top: 4px;">z.B. EURUSD, GBPUSD, USDJPY, XAUUSD, US100 – gilt fuer alle Accounts ohne eigene Watchlist</div>

        <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center" Style="margin-top: 12px;">
            <RadzenButton Text="Symbole vom Broker laden" Icon="download" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small" Click="@LoadBrokerSymbols" Disabled="@_loadingSymbols" />
            @if (_loadingSymbols)
            {
                <RadzenText Style="color: var(--muted); font-size: 0.85rem;">Lade...</RadzenText>
            }
            @if (_brokerSymbols.Count > 0)
            {
                <RadzenText Style="color: var(--muted); font-size: 0.85rem;">@_brokerSymbols.Count Symbole verfuegbar</RadzenText>
            }
        </RadzenStack>

        @if (_brokerSymbols.Count > 0)
        {
            <div style="margin-top: 12px; padding: 12px; background: var(--bg-raised); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); max-height: 200px; overflow-y: auto;">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="6px" Wrap="FlexWrap.Wrap">
                    @foreach (var sym in _brokerSymbols)
                    {
                        var isSelected = _currentWatchSymbols.Contains(sym);
                        <RadzenButton Text="@sym" Size="ButtonSize.ExtraSmall"
                                      ButtonStyle="@(isSelected ? ButtonStyle.Primary : ButtonStyle.Light)"
                                      Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                      Click="@(() => ToggleSymbol(sym))"
                                      Style="font-size: 0.75rem; padding: 2px 8px;" />
                    }
                </RadzenStack>
            </div>
        }
    </RadzenCard>

    <!-- Multi-Timeframe -->
    <RadzenCard Style="margin-bottom: 24px;">
        <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">Multi-Timeframe Bestaetigung</h3>
        <RadzenRow Gap="16px">
            <RadzenColumn Size="4">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                    <RadzenCheckBox @bind-Value="MultiTimeframeEnabled" />
                    <RadzenLabel Text="Multi-Timeframe-Filter aktivieren" />
                </RadzenStack>
                <div class="hint" style="margin-top: 4px;">Trades nur in Richtung des hoeheren Timeframe-Trends</div>
            </RadzenColumn>
            <RadzenColumn Size="4">
                <RadzenLabel Text="Hoeherer Timeframe" Style="display: block; margin-bottom: 4px;" />
                <RadzenDropDown @bind-Value="MultiTimeframeHigherTf" Data="_timeframeOptions" TextProperty="Text" ValueProperty="Value" Style="width: 100%;" />
            </RadzenColumn>
            <RadzenColumn Size="4">
                <RadzenLabel Text="EMA-Periode" Style="display: block; margin-bottom: 4px;" />
                <RadzenNumeric TValue="int" @bind-Value="MultiTimeframeEmaPeriod" ShowUpDown="false" Min="10" Max="500" Style="width: 100%;" />
                <div class="hint" style="margin-top: 4px;">z.B. 200 fuer EMA200</div>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>

    <!-- News & Sentiment -->
    <RadzenCard Style="margin-bottom: 24px;">
        <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">News & Sentiment</h3>
        <RadzenRow Gap="16px">
            <RadzenColumn Size="12">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                    <RadzenCheckBox @bind-Value="NewsEnabled" />
                    <RadzenLabel Text="News-Sentiment-Analyse aktivieren" />
                </RadzenStack>
                <div class="hint" style="margin-top: 4px;">Beruecksichtigt Finanznachrichten bei der Analyse</div>
            </RadzenColumn>
            <RadzenColumn Size="6">
                <RadzenLabel Text="Finnhub API Key" Style="display: block; margin-bottom: 4px;" />
                <RadzenTextBox @bind-Value="NewsApiKey" Placeholder="Finnhub API Key" Style="width: 100%;" />
                <div class="hint" style="margin-top: 4px;">Kostenlos unter finnhub.io erhaeltlich</div>
            </RadzenColumn>
            <RadzenColumn Size="3">
                <RadzenLabel Text="Max. Headlines" Style="display: block; margin-bottom: 4px;" />
                <RadzenNumeric TValue="int" @bind-Value="NewsMaxHeadlines" ShowUpDown="false" Min="1" Max="20" Style="width: 100%;" />
            </RadzenColumn>
            <RadzenColumn Size="3">
                <RadzenLabel Text="Refresh (Min.)" Style="display: block; margin-bottom: 4px;" />
                <RadzenNumeric TValue="int" @bind-Value="NewsRefreshInterval" ShowUpDown="false" Min="15" Max="1440" Style="width: 100%;" />
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>

    <RadzenButton Text="Einstellungen Speichern" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" />
</EditForm>

<!-- API-Konfiguration (readonly) -->
<RadzenCard Style="margin-top: 24px;">
    <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">API-Konfiguration (nur Anzeige)</h3>
    <RadzenRow Gap="16px">
        <RadzenColumn Size="6">
            <RadzenLabel Text="LLM Provider" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_llmProvider" ReadOnly="true" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="TradeLocker Email" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_tradeLockerEmail" ReadOnly="true" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="Anthropic API Key" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_anthropicKeyMasked" ReadOnly="true" Style="width: 100%;" />
            <div class="hint" style="margin-top: 2px;">Model: @_anthropicModel, MaxTokens: @_anthropicMaxTokens</div>
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="Gemini API Key" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_geminiKeyMasked" ReadOnly="true" Style="width: 100%;" />
            <div class="hint" style="margin-top: 2px;">Model: @_geminiModel, MaxTokens: @_geminiMaxTokens</div>
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="OpenAI-Compatible API Key" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_openAIKeyMasked" ReadOnly="true" Style="width: 100%;" />
            <div class="hint" style="margin-top: 2px;">Model: @_openAIModel, MaxTokens: @_openAIMaxTokens</div>
        </RadzenColumn>
    </RadzenRow>
    <div class="hint" style="margin-top: 8px;">API-Keys koennen nur direkt in appsettings.json geaendert werden.</div>
</RadzenCard>

<!-- Wartung -->
<RadzenCard Style="margin-top: 24px;">
    <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">Wartung</h3>

    @if (!string.IsNullOrEmpty(_purgeResult))
    {
        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" AllowClose="true" Close="@(() => _purgeResult = null)" Style="margin-bottom: 12px;">
            @_purgeResult
        </RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="12px" AlignItems="AlignItems.Center">
        <RadzenButton Text="Trading-Daten zuruecksetzen" Icon="delete_sweep" ButtonStyle="ButtonStyle.Danger"
                      Click="@PurgeTradeData" />
        <span style="color: var(--muted); font-size: 0.85rem;">
            Loescht Trades, Positionen, PnL-Historie, Logs, Grid-States und Engine-Snapshots.
            Benutzer, Accounts und Einstellungen bleiben erhalten.
        </span>
    </RadzenStack>
</RadzenCard>

@code {
    private string WatchList { get; set; } = string.Empty;

    // Multi-Timeframe
    private bool MultiTimeframeEnabled { get; set; }
    private string MultiTimeframeHigherTf { get; set; } = "4H";
    private int MultiTimeframeEmaPeriod { get; set; } = 200;

    // News Settings
    private bool NewsEnabled { get; set; }
    private string NewsApiKey { get; set; } = string.Empty;
    private int NewsMaxHeadlines { get; set; } = 5;
    private int NewsRefreshInterval { get; set; } = 60;

    private string _llmProvider = string.Empty;
    private string _anthropicKeyMasked = string.Empty;
    private string _anthropicModel = string.Empty;
    private int _anthropicMaxTokens;
    private string _geminiKeyMasked = string.Empty;
    private string _geminiModel = string.Empty;
    private int _geminiMaxTokens;
    private string _openAIKeyMasked = string.Empty;
    private string _openAIModel = string.Empty;
    private int _openAIMaxTokens;
    private string _tradeLockerEmail = string.Empty;

    private bool _saveSuccess;
    private List<string> _errors = new();
    private List<string> _brokerSymbols = new();
    private HashSet<string> _currentWatchSymbols = new(StringComparer.OrdinalIgnoreCase);
    private bool _loadingSymbols;
    private string? _purgeResult;

    private record DropDownItem(string Text, string Value);
    private List<DropDownItem> _timeframeOptions = new()
    {
        new("4H", "4H"), new("1D", "1D")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentValuesAsync();
    }

    private async Task SaveSettings()
    {
        _saveSuccess = false;
        _errors = new List<string>();

        try
        {
            // Global WatchList in DB speichern
            var watchItems = WatchList
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
            await SettingsRepo.SaveGlobalWatchListAsync(watchItems);

            // MultiTimeframe in DB speichern
            var mtf = new MultiTimeframeSettings
            {
                Enabled = MultiTimeframeEnabled,
                HigherTimeframe = MultiTimeframeHigherTf,
                EmaPeriod = MultiTimeframeEmaPeriod
            };
            await SettingsRepo.SaveMultiTimeframeSettingsAsync(mtf);

            // NewsSettings in DB speichern
            var news = new NewsSettings
            {
                Enabled = NewsEnabled,
                FinnhubApiKey = NewsApiKey,
                MaxHeadlinesPerSymbol = NewsMaxHeadlines,
                RefreshIntervalMinutes = NewsRefreshInterval
            };
            await SettingsRepo.SaveNewsSettingsAsync(news);

            _saveSuccess = true;
            await LoadCurrentValuesAsync();
        }
        catch (Exception ex)
        {
            _errors.Add($"Fehler beim Speichern: {ex.Message}");
        }
    }

    private async Task LoadCurrentValuesAsync()
    {
        // Watchlist aus DB
        var globalWatchList = await SettingsRepo.GetGlobalWatchListAsync();
        WatchList = string.Join(", ", globalWatchList);

        // MultiTimeframe aus DB
        var mtf = await SettingsRepo.GetMultiTimeframeSettingsAsync();
        MultiTimeframeEnabled = mtf.Enabled;
        MultiTimeframeHigherTf = mtf.HigherTimeframe;
        MultiTimeframeEmaPeriod = mtf.EmaPeriod;

        // NewsSettings aus DB
        var news = await SettingsRepo.GetNewsSettingsAsync();
        NewsEnabled = news.Enabled;
        NewsApiKey = news.FinnhubApiKey;
        NewsMaxHeadlines = news.MaxHeadlinesPerSymbol;
        NewsRefreshInterval = news.RefreshIntervalMinutes;

        // API-Config bleibt in appsettings.json (readonly)
        _llmProvider = Configuration.GetValue<string>("Llm:Provider") ?? "Gemini";
        _anthropicKeyMasked = MaskKey(Configuration.GetValue<string>("Anthropic:ApiKey"));
        _anthropicModel = Configuration.GetValue<string>("Anthropic:Model") ?? "claude-sonnet-4-20250514";
        _anthropicMaxTokens = Configuration.GetValue<int>("Anthropic:MaxTokens", 2048);

        _geminiKeyMasked = MaskKey(Configuration.GetValue<string>("Gemini:ApiKey"));
        _geminiModel = Configuration.GetValue<string>("Gemini:Model") ?? "gemini-2.0-flash-lite";
        _geminiMaxTokens = Configuration.GetValue<int>("Gemini:MaxTokens", 2048);

        _openAIKeyMasked = MaskKey(Configuration.GetValue<string>("OpenAICompatible:ApiKey"));
        _openAIModel = Configuration.GetValue<string>("OpenAICompatible:Model") ?? "qwen2.5:7b";
        _openAIMaxTokens = Configuration.GetValue<int>("OpenAICompatible:MaxTokens", 2048);

        _tradeLockerEmail = Configuration.GetValue<string>("TradeLocker:Email") ?? string.Empty;
    }

    private async Task LoadBrokerSymbols()
    {
        _loadingSymbols = true;
        _brokerSymbols = new();
        StateHasChanged();

        try
        {
            // Vom ersten verbundenen Account die Symbole laden
            var ctx = AccountMgr.Accounts.FirstOrDefault(a => a.EffectiveBroker.IsConnected);
            if (ctx is null)
            {
                _errors.Add("Kein Account verbunden. Bitte zuerst einen Account unter Accounts anlegen und verbinden.");
                return;
            }

            _brokerSymbols = ctx.Broker.GetAvailableSymbols();
            _currentWatchSymbols = WatchList
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            if (_brokerSymbols.Count == 0)
                _errors.Add("Broker hat keine Instrumente geladen. Ist der Account verbunden?");
        }
        catch (Exception ex)
        {
            _errors.Add($"Fehler beim Laden: {ex.Message}");
        }
        finally
        {
            _loadingSymbols = false;
        }
    }

    private void ToggleSymbol(string symbol)
    {
        if (_currentWatchSymbols.Contains(symbol))
            _currentWatchSymbols.Remove(symbol);
        else
            _currentWatchSymbols.Add(symbol);

        WatchList = string.Join(", ", _currentWatchSymbols.OrderBy(s => s));
    }

    private async Task PurgeTradeData()
    {
        var confirmed = await DialogService.Confirm(
            "Alle Trading-Daten loeschen? Dies umfasst Trades, Positionen, PnL-Historie, Logs, Grid-States und Engine-Snapshots. " +
            "Benutzer, Accounts und Einstellungen bleiben erhalten. Diese Aktion kann nicht rueckgaengig gemacht werden.",
            "Trading-Daten zuruecksetzen",
            new ConfirmOptions { OkButtonText = "Endgueltig loeschen", CancelButtonText = "Abbrechen" });

        if (confirmed != true) return;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var trades = await db.Trades.ExecuteDeleteAsync();
            var positions = await db.Positions.ExecuteDeleteAsync();
            var pnl = await db.DailyPnLs.ExecuteDeleteAsync();
            var logs = await db.TradingLogs.ExecuteDeleteAsync();
            var grids = await db.GridStates.ExecuteDeleteAsync();
            var snapshots = await db.EngineStateSnapshots.ExecuteDeleteAsync();

            _purgeResult = $"Geloescht: {trades} Trades, {positions} Positionen, {pnl} PnL-Eintraege, " +
                           $"{logs} Logs, {grids} Grid-States, {snapshots} Snapshots.";
        }
        catch (Exception ex)
        {
            _errors.Add($"Fehler beim Loeschen: {ex.Message}");
        }
    }

    private static string MaskKey(string? key)
    {
        if (string.IsNullOrEmpty(key))
            return "(nicht gesetzt)";
        if (key.Length <= 8)
            return "***";
        return key[..4] + "***" + key[^4..];
    }
}
