@page "/settings"
@using ClaudeTradingBot.Models
@using ClaudeTradingBot.Services
@inject ISettingsRepository SettingsRepo
@inject AccountManager AccountMgr
@inject IConfiguration Configuration

<PageTitle>Einstellungen - Claude Trading Bot</PageTitle>

<h2 style="margin-bottom: 24px;">Einstellungen</h2>

<div class="warning-banner">
    Aenderungen werden in die Datenbank geschrieben und sind sofort wirksam (kein Neustart noetig).
</div>

@if (_saveSuccess)
{
    <div class="success-banner">Einstellungen erfolgreich gespeichert.</div>
}

@if (_errors.Any())
{
    <div class="error-banner">
        <strong>Validierungsfehler:</strong>
        <ul style="margin: 8px 0 0 16px; list-style: disc;">
            @foreach (var error in _errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

<EditForm Model="this" OnValidSubmit="SaveSettings" FormName="settings">
    <!-- Watchlist -->
    <div class="form-section">
        <h3>Watchlist</h3>
        <div class="form-group">
            <label>Symbole (komma-separiert)</label>
            <textarea rows="3" @bind="WatchList"></textarea>
            <div class="hint">z.B. EURUSD, GBPUSD, USDJPY, XAUUSD, US100</div>
        </div>
    </div>

    <!-- Risiko-Parameter -->
    <div class="form-section">
        <h3>Risiko-Parameter</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label>Min. Confidence</label>
                <input type="number" @bind="MinConfidence" step="0.01" min="0" max="1" />
                <div class="hint">Minimale KI-Confidence fuer Trade-Ausfuehrung (0-1)</div>
            </div>
            <div class="form-group">
                <label>Max. Positionsgroesse (%)</label>
                <input type="number" @bind="MaxPositionSizePercent" step="0.5" min="0" />
                <div class="hint">Maximaler Anteil am Portfolio pro Trade</div>
            </div>
            <div class="form-group">
                <label>Max. Tagesverlust (%)</label>
                <input type="number" @bind="MaxDailyLossPercent" step="0.1" min="0" />
                <div class="hint">Prozentualer Tagesverlust-Limit</div>
            </div>
            <div class="form-group">
                <label>Max. Tagesverlust (absolut)</label>
                <input type="number" @bind="MaxDailyLossAbsolute" step="10" min="0" />
                <div class="hint">Absoluter Tagesverlust-Limit in $</div>
            </div>
            <div class="form-group">
                <label>Stop-Loss (%)</label>
                <input type="number" @bind="StopLossPercent" step="0.1" min="0" />
                <div class="hint">Automatischer Stop-Loss pro Position</div>
            </div>
            <div class="form-group">
                <label>Max. offene Positionen</label>
                <input type="number" @bind="MaxOpenPositions" min="1" />
            </div>
        </div>
    </div>

    <!-- Intervall -->
    <div class="form-section">
        <h3>Trading-Intervall</h3>
        <div class="form-group">
            <label>Analyse-Intervall (Minuten)</label>
            <input type="number" @bind="TradingIntervalMinutes" min="1" />
            <div class="hint">Wie oft die Engine Marktdaten analysiert und Trades evaluiert</div>
        </div>
    </div>

    <!-- Paper-Trading -->
    <div class="form-section">
        <h3>Paper-Trading</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="PaperTradingEnabled" style="margin-right: 8px;" />
                    Paper-Trading aktivieren
                </label>
                <div class="hint">Wenn aktiv werden keine echten Orders platziert. Echte Marktdaten fliessen weiterhin.</div>
            </div>
            <div class="form-group">
                <label>Startkapital (Paper)</label>
                <input type="number" @bind="PaperTradingBalance" step="100" min="100" />
                <div class="hint">Simuliertes Startkapital fuer Paper-Trading</div>
            </div>
        </div>
    </div>

    <!-- Multi-Timeframe -->
    <div class="form-section">
        <h3>Multi-Timeframe Bestaetigung</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px;">
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="MultiTimeframeEnabled" style="margin-right: 8px;" />
                    Multi-Timeframe-Filter aktivieren
                </label>
                <div class="hint">Trades nur in Richtung des hoeheren Timeframe-Trends</div>
            </div>
            <div class="form-group">
                <label>Hoeherer Timeframe</label>
                <select @bind="MultiTimeframeHigherTf">
                    <option value="4H">4H</option>
                    <option value="1D">1D</option>
                </select>
            </div>
            <div class="form-group">
                <label>EMA-Periode</label>
                <input type="number" @bind="MultiTimeframeEmaPeriod" min="10" max="500" />
                <div class="hint">z.B. 200 fuer EMA200</div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Einstellungen Speichern</button>
</EditForm>

<!-- API-Konfiguration (readonly) -->
<div class="form-section" style="margin-top: 24px;">
    <h3>API-Konfiguration (nur Anzeige)</h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <div class="form-group">
            <label>LLM Provider</label>
            <input type="text" value="@_llmProvider" readonly />
        </div>
        <div class="form-group">
            <label>TradeLocker Email</label>
            <input type="text" value="@_tradeLockerEmail" readonly />
        </div>
        <div class="form-group">
            <label>Anthropic API Key</label>
            <input type="text" value="@_anthropicKeyMasked" readonly />
        </div>
        <div class="form-group">
            <label>Gemini API Key</label>
            <input type="text" value="@_geminiKeyMasked" readonly />
        </div>
        <div class="form-group">
            <label>OpenAI-Compatible API Key</label>
            <input type="text" value="@_openAIKeyMasked" readonly />
        </div>
    </div>
    <div class="hint" style="margin-top: 8px;">API-Keys koennen nur direkt in appsettings.json geaendert werden.</div>
</div>

@code {
    private string WatchList { get; set; } = string.Empty;
    private double MinConfidence { get; set; }
    private double MaxPositionSizePercent { get; set; }
    private double MaxDailyLossPercent { get; set; }
    private double StopLossPercent { get; set; }
    private int MaxOpenPositions { get; set; }
    private int TradingIntervalMinutes { get; set; }
    private decimal MaxDailyLossAbsolute { get; set; }

    // Paper-Trading
    private bool PaperTradingEnabled { get; set; }
    private decimal PaperTradingBalance { get; set; } = 10000m;

    // Multi-Timeframe
    private bool MultiTimeframeEnabled { get; set; }
    private string MultiTimeframeHigherTf { get; set; } = "4H";
    private int MultiTimeframeEmaPeriod { get; set; } = 200;

    private string _llmProvider = string.Empty;
    private string _anthropicKeyMasked = string.Empty;
    private string _geminiKeyMasked = string.Empty;
    private string _openAIKeyMasked = string.Empty;
    private string _tradeLockerEmail = string.Empty;

    private bool _saveSuccess;
    private List<string> _errors = new();

    // Gewaehlter Account (Default-Account fuer globale Settings)
    private string _selectedAccountId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _selectedAccountId = AccountMgr.DefaultAccount?.AccountId ?? string.Empty;
        await LoadCurrentValuesAsync();
    }

    private async Task SaveSettings()
    {
        _saveSuccess = false;
        _errors = new List<string>();

        // Validierung
        if (MinConfidence < 0 || MinConfidence > 1)
            _errors.Add("Min. Confidence muss zwischen 0 und 1 liegen.");
        if (MaxPositionSizePercent <= 0)
            _errors.Add("Max. Positionsgroesse muss > 0 sein.");
        if (MaxDailyLossPercent <= 0)
            _errors.Add("Max. Tagesverlust muss > 0 sein.");
        if (StopLossPercent <= 0)
            _errors.Add("Stop-Loss muss > 0 sein.");
        if (MaxOpenPositions < 1)
            _errors.Add("Max. offene Positionen muss >= 1 sein.");
        if (TradingIntervalMinutes < 1)
            _errors.Add("Trading-Intervall muss >= 1 Minute sein.");
        if (MaxDailyLossAbsolute <= 0)
            _errors.Add("Max. Tagesverlust (absolut) muss > 0 sein.");

        if (_errors.Any())
            return;

        try
        {
            // Global WatchList in DB speichern
            var watchItems = WatchList
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
            await SettingsRepo.SaveGlobalWatchListAsync(watchItems);

            // Account-spezifische Settings in DB speichern
            var account = await SettingsRepo.GetAccountAsync(_selectedAccountId);
            if (account != null)
            {
                account.RiskManagement.MinConfidence = MinConfidence;
                account.RiskManagement.MaxPositionSizePercent = MaxPositionSizePercent;
                account.RiskManagement.MaxDailyLossPercent = MaxDailyLossPercent;
                account.RiskManagement.StopLossPercent = StopLossPercent;
                account.RiskManagement.MaxOpenPositions = MaxOpenPositions;
                account.RiskManagement.TradingIntervalMinutes = TradingIntervalMinutes;
                account.RiskManagement.MaxDailyLossAbsolute = MaxDailyLossAbsolute;
                account.PaperTrading.Enabled = PaperTradingEnabled;
                account.PaperTrading.InitialBalance = PaperTradingBalance;
                await SettingsRepo.SaveAccountAsync(account);

                // Hot-Reload
                await AccountMgr.ReloadAccountSettingsAsync(_selectedAccountId);
            }

            // MultiTimeframe in DB speichern
            var mtf = new MultiTimeframeSettings
            {
                Enabled = MultiTimeframeEnabled,
                HigherTimeframe = MultiTimeframeHigherTf,
                EmaPeriod = MultiTimeframeEmaPeriod
            };
            await SettingsRepo.SaveMultiTimeframeSettingsAsync(mtf);

            _saveSuccess = true;
            await LoadCurrentValuesAsync();
        }
        catch (Exception ex)
        {
            _errors.Add($"Fehler beim Speichern: {ex.Message}");
        }
    }

    private async Task LoadCurrentValuesAsync()
    {
        // Watchlist aus DB
        var globalWatchList = await SettingsRepo.GetGlobalWatchListAsync();
        WatchList = string.Join(", ", globalWatchList);

        // Account-Settings aus DB
        var account = await SettingsRepo.GetAccountAsync(_selectedAccountId);
        if (account != null)
        {
            MinConfidence = account.RiskManagement.MinConfidence;
            MaxPositionSizePercent = account.RiskManagement.MaxPositionSizePercent;
            MaxDailyLossPercent = account.RiskManagement.MaxDailyLossPercent;
            StopLossPercent = account.RiskManagement.StopLossPercent;
            MaxOpenPositions = account.RiskManagement.MaxOpenPositions;
            TradingIntervalMinutes = account.RiskManagement.TradingIntervalMinutes;
            MaxDailyLossAbsolute = account.RiskManagement.MaxDailyLossAbsolute;
            PaperTradingEnabled = account.PaperTrading.Enabled;
            PaperTradingBalance = account.PaperTrading.InitialBalance;
        }

        // MultiTimeframe aus DB
        var mtf = await SettingsRepo.GetMultiTimeframeSettingsAsync();
        MultiTimeframeEnabled = mtf.Enabled;
        MultiTimeframeHigherTf = mtf.HigherTimeframe;
        MultiTimeframeEmaPeriod = mtf.EmaPeriod;

        // API-Config bleibt in appsettings.json (readonly)
        _llmProvider = Configuration.GetValue<string>("Llm:Provider") ?? "Gemini";
        _anthropicKeyMasked = MaskKey(Configuration.GetValue<string>("Anthropic:ApiKey"));
        _geminiKeyMasked = MaskKey(Configuration.GetValue<string>("Gemini:ApiKey"));
        _openAIKeyMasked = MaskKey(Configuration.GetValue<string>("OpenAICompatible:ApiKey"));
        _tradeLockerEmail = Configuration.GetValue<string>("TradeLocker:Email") ?? string.Empty;
    }

    private static string MaskKey(string? key)
    {
        if (string.IsNullOrEmpty(key))
            return "(nicht gesetzt)";
        if (key.Length <= 8)
            return "***";
        return key[..4] + "***" + key[^4..];
    }
}
