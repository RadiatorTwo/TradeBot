@page "/settings"
@using ClaudeTradingBot.Models
@using ClaudeTradingBot.Services
@inject ISettingsRepository SettingsRepo
@inject AccountManager AccountMgr
@inject IConfiguration Configuration

<PageTitle>Einstellungen - Claude Trading Bot</PageTitle>

<h2 style="margin-bottom: 24px;">Globale Einstellungen</h2>

<RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false" Style="margin-bottom: 24px;">
    Hier werden globale Einstellungen verwaltet, die fuer alle Accounts gelten.
    Account-spezifische Einstellungen (Risiko, Intervall, Paper-Trading) werden unter <a href="/accounts" style="color: var(--accent);">/accounts</a> pro Account konfiguriert.
</RadzenAlert>

@if (_saveSuccess)
{
    <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="true" Style="margin-bottom: 24px;">
        Einstellungen erfolgreich gespeichert.
    </RadzenAlert>
}

@if (_errors.Any())
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false" Style="margin-bottom: 24px;">
        <strong>Validierungsfehler:</strong>
        <ul style="margin: 8px 0 0 16px; list-style: disc;">
            @foreach (var error in _errors)
            {
                <li>@error</li>
            }
        </ul>
    </RadzenAlert>
}

<EditForm Model="this" OnValidSubmit="SaveSettings" FormName="settings">
    <!-- Watchlist -->
    <RadzenCard Style="margin-bottom: 24px;">
        <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">Watchlist</h3>
        <RadzenLabel Text="Symbole (komma-separiert)" Style="display: block; margin-bottom: 4px;" />
        <RadzenTextArea @bind-Value="WatchList" Rows="3" Style="width: 100%;" />
        <div class="hint" style="margin-top: 4px;">z.B. EURUSD, GBPUSD, USDJPY, XAUUSD, US100 – gilt fuer alle Accounts ohne eigene Watchlist</div>
    </RadzenCard>

    <!-- Multi-Timeframe -->
    <RadzenCard Style="margin-bottom: 24px;">
        <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">Multi-Timeframe Bestaetigung</h3>
        <RadzenRow Gap="16px">
            <RadzenColumn Size="4">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                    <RadzenCheckBox @bind-Value="MultiTimeframeEnabled" />
                    <RadzenLabel Text="Multi-Timeframe-Filter aktivieren" />
                </RadzenStack>
                <div class="hint" style="margin-top: 4px;">Trades nur in Richtung des hoeheren Timeframe-Trends</div>
            </RadzenColumn>
            <RadzenColumn Size="4">
                <RadzenLabel Text="Hoeherer Timeframe" Style="display: block; margin-bottom: 4px;" />
                <RadzenDropDown @bind-Value="MultiTimeframeHigherTf" Data="_timeframeOptions" TextProperty="Text" ValueProperty="Value" Style="width: 100%;" />
            </RadzenColumn>
            <RadzenColumn Size="4">
                <RadzenLabel Text="EMA-Periode" Style="display: block; margin-bottom: 4px;" />
                <RadzenNumeric TValue="int" @bind-Value="MultiTimeframeEmaPeriod" ShowUpDown="false" Min="10" Max="500" Style="width: 100%;" />
                <div class="hint" style="margin-top: 4px;">z.B. 200 fuer EMA200</div>
            </RadzenColumn>
        </RadzenRow>
    </RadzenCard>

    <RadzenButton Text="Einstellungen Speichern" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" />
</EditForm>

<!-- API-Konfiguration (readonly) -->
<RadzenCard Style="margin-top: 24px;">
    <h3 style="margin-top: 0; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border);">API-Konfiguration (nur Anzeige)</h3>
    <RadzenRow Gap="16px">
        <RadzenColumn Size="6">
            <RadzenLabel Text="LLM Provider" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_llmProvider" ReadOnly="true" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="TradeLocker Email" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_tradeLockerEmail" ReadOnly="true" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="Anthropic API Key" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_anthropicKeyMasked" ReadOnly="true" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="Gemini API Key" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_geminiKeyMasked" ReadOnly="true" Style="width: 100%;" />
        </RadzenColumn>
        <RadzenColumn Size="6">
            <RadzenLabel Text="OpenAI-Compatible API Key" Style="display: block; margin-bottom: 4px;" />
            <RadzenTextBox Value="@_openAIKeyMasked" ReadOnly="true" Style="width: 100%;" />
        </RadzenColumn>
    </RadzenRow>
    <div class="hint" style="margin-top: 8px;">API-Keys koennen nur direkt in appsettings.json geaendert werden.</div>
</RadzenCard>

@code {
    private string WatchList { get; set; } = string.Empty;

    // Multi-Timeframe
    private bool MultiTimeframeEnabled { get; set; }
    private string MultiTimeframeHigherTf { get; set; } = "4H";
    private int MultiTimeframeEmaPeriod { get; set; } = 200;

    private string _llmProvider = string.Empty;
    private string _anthropicKeyMasked = string.Empty;
    private string _geminiKeyMasked = string.Empty;
    private string _openAIKeyMasked = string.Empty;
    private string _tradeLockerEmail = string.Empty;

    private bool _saveSuccess;
    private List<string> _errors = new();

    private record DropDownItem(string Text, string Value);
    private List<DropDownItem> _timeframeOptions = new()
    {
        new("4H", "4H"), new("1D", "1D")
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentValuesAsync();
    }

    private async Task SaveSettings()
    {
        _saveSuccess = false;
        _errors = new List<string>();

        try
        {
            // Global WatchList in DB speichern
            var watchItems = WatchList
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();
            await SettingsRepo.SaveGlobalWatchListAsync(watchItems);

            // MultiTimeframe in DB speichern
            var mtf = new MultiTimeframeSettings
            {
                Enabled = MultiTimeframeEnabled,
                HigherTimeframe = MultiTimeframeHigherTf,
                EmaPeriod = MultiTimeframeEmaPeriod
            };
            await SettingsRepo.SaveMultiTimeframeSettingsAsync(mtf);

            _saveSuccess = true;
            await LoadCurrentValuesAsync();
        }
        catch (Exception ex)
        {
            _errors.Add($"Fehler beim Speichern: {ex.Message}");
        }
    }

    private async Task LoadCurrentValuesAsync()
    {
        // Watchlist aus DB
        var globalWatchList = await SettingsRepo.GetGlobalWatchListAsync();
        WatchList = string.Join(", ", globalWatchList);

        // MultiTimeframe aus DB
        var mtf = await SettingsRepo.GetMultiTimeframeSettingsAsync();
        MultiTimeframeEnabled = mtf.Enabled;
        MultiTimeframeHigherTf = mtf.HigherTimeframe;
        MultiTimeframeEmaPeriod = mtf.EmaPeriod;

        // API-Config bleibt in appsettings.json (readonly)
        _llmProvider = Configuration.GetValue<string>("Llm:Provider") ?? "Gemini";
        _anthropicKeyMasked = MaskKey(Configuration.GetValue<string>("Anthropic:ApiKey"));
        _geminiKeyMasked = MaskKey(Configuration.GetValue<string>("Gemini:ApiKey"));
        _openAIKeyMasked = MaskKey(Configuration.GetValue<string>("OpenAICompatible:ApiKey"));
        _tradeLockerEmail = Configuration.GetValue<string>("TradeLocker:Email") ?? string.Empty;
    }

    private static string MaskKey(string? key)
    {
        if (string.IsNullOrEmpty(key))
            return "(nicht gesetzt)";
        if (key.Length <= 8)
            return "***";
        return key[..4] + "***" + key[^4..];
    }
}
