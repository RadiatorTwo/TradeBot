@inject DialogService DialogService

<RadzenStack Gap="12px">
    <RadzenText>Neues Passwort fuer <strong>@Username</strong>:</RadzenText>
    <RadzenPassword @bind-Value="_newPassword" Placeholder="Min. 8 Zeichen" Style="width: 100%;" />

    @if (!string.IsNullOrEmpty(_error))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Size="AlertSize.Small">@_error</RadzenAlert>
    }

    <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" JustifyContent="JustifyContent.End">
        <RadzenButton Text="Zuruecksetzen" ButtonStyle="ButtonStyle.Primary" Click="@Submit" />
        <RadzenButton Text="Abbrechen" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close())" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public string Username { get; set; } = "";

    private string _newPassword = "";
    private string? _error;

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 8)
        {
            _error = "Das Passwort muss mindestens 8 Zeichen lang sein.";
            return;
        }

        DialogService.Close(_newPassword);
    }
}
