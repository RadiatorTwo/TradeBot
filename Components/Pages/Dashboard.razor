@page "/"
@using ClaudeTradingBot.Data
@using ClaudeTradingBot.Hubs
@using Microsoft.EntityFrameworkCore
@inject AccountManager AccountMgr
@inject MarketHoursService MarketHours
@inject EconomicCalendarService Calendar
@inject IDbContextFactory<TradingDbContext> DbFactory
@inject NavigationManager Navigation
@inject DialogService DialogService
@implements IAsyncDisposable

<PageTitle>Dashboard - NeuronTrade</PageTitle>

@if (!AccountMgr.HasAccounts)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false" Style="margin-bottom: 24px;">
        <strong>Kein Account konfiguriert.</strong> Bitte unter <a href="/accounts">Accounts</a> einen Account anlegen um den Trading Bot zu starten.
    </RadzenAlert>
}
else
{

@if (AccountMgr.Accounts.Count > 1)
{
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" Style="margin-bottom: 12px;">
        <RadzenLabel Text="Account:" />
        <RadzenDropDown @bind-Value="_selectedAccountId"
                        Data="AccountMgr.Accounts"
                        TextProperty="DisplayName"
                        ValueProperty="AccountId"
                        Change="@(args => OnAccountChanged())"
                        Style="min-width: 250px;" />
    </RadzenStack>
}

<div class="status-badges" style="margin-bottom: 24px;">
    @{ var engineText = vm.IsEnginePaused ? "Engine Pausiert" : vm.IsEngineRunning ? "Engine Laeuft" : "Engine Wartet"; }
    @{ var engineColor = vm.IsEnginePaused ? "red" : vm.IsEngineRunning ? "green" : "yellow"; }
    <StatusBadge Text="@engineText" Color="@engineColor" />
    <StatusBadge Text="@(vm.IsTradeLockerConnected ? "TradeLocker Verbunden" : "TradeLocker Getrennt")"
                 Color="@(vm.IsTradeLockerConnected ? "green" : "red")" />
    @if (vm.IsPaperTrading)
    {
        <StatusBadge Text="Paper-Trading Aktiv" Color="yellow" />
    }
    @if (vm.IsKillSwitchActive)
    {
        <StatusBadge Text="Kill Switch Aktiv" Color="red" />
    }
    <StatusBadge Text="@($"Markt {vm.MarketStatus}")"
                 Color="@(vm.IsMarketOpen ? "green" : "red")" />
    <StatusBadge Text="@($"{LocalTime.FromUtc(DateTime.UtcNow):HH:mm}")" Color="blue" />
</div>

<!-- Konto-Uebersicht -->
<div class="stats-grid">
    <StatCard Label="Eigenkapital (Equity)" Value="@($"${vm.Account.Equity:N2}")" />
    <StatCard Label="Kontostand (Balance)" Value="@($"${vm.Account.Balance:N2}")" />
    <StatCard Label="Unrealisierter P&L"
              Value="@($"{(vm.Account.UnrealizedPnL >= 0 ? "+" : "")}${vm.Account.UnrealizedPnL:N2}")"
              CssClass="@(vm.Account.UnrealizedPnL >= 0 ? "stat-positive" : "stat-negative")" />
    <StatCard Label="Verwendete Margin" Value="@($"${vm.Account.Margin:N2}")" />
    <StatCard Label="Verfuegbare Margin" Value="@($"${vm.Account.FreeMargin:N2}")" />
    @if (vm.Account.Margin > 0)
    {
        <StatCard Label="Margin-Nutzung"
                  Value="@($"{vm.Account.MarginUsagePercent:F2}%")"
                  CssClass="@(vm.Account.MarginUsagePercent <= 50 ? "stat-positive" : vm.Account.MarginUsagePercent <= 80 ? "" : "stat-negative")" />
    }
    <StatCard Label="Offene Positionen" Value="@vm.OpenPositions.ToString()" />
    <StatCard Label="Trades Heute" Value="@vm.TradesToday.ToString()" />
</div>

<!-- Controls -->
<RadzenStack Orientation="Orientation.Horizontal" Gap="12px" Style="margin-bottom: 32px;" Wrap="FlexWrap.Wrap">
    @if (vm.IsEnginePaused)
    {
        <RadzenButton Text="Engine Starten" ButtonStyle="ButtonStyle.Primary" Click="@ResumeEngine" />
    }
    else
    {
        <RadzenButton Text="Engine Pausieren" Variant="Variant.Outlined" Click="@PauseEngine" />
    }
    <RadzenButton Text="Kill Switch" ButtonStyle="ButtonStyle.Danger" Click="@ActivateKillSwitch" />
    @if (vm.IsKillSwitchActive)
    {
        <RadzenButton Text="Kill Switch Reset" ButtonStyle="ButtonStyle.Success" Click="@ResetKillSwitch" />
    }
</RadzenStack>

<!-- Equity-Kurve -->
<EquityChart PnLHistory="vm.PnLHistory" />

<!-- Performance-Statistiken -->
<TradingStats Stats="vm.Stats" />

<!-- Naechste High-Impact Events -->
@if (vm.UpcomingEvents.Any())
{
    <div class="section">
        <h2>Naechste High-Impact Events</h2>
        <RadzenDataGrid Data="@vm.UpcomingEvents" TItem="UpcomingEventViewModel" Density="Density.Compact" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="UpcomingEventViewModel" Property="EventTime" Title="Zeit (UTC)" Width="160px">
                    <Template Context="evt">@LocalTime.Format(evt.EventTime, "dd.MM. HH:mm")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UpcomingEventViewModel" Property="Currency" Title="Waehrung" Width="100px">
                    <Template Context="evt"><strong>@evt.Currency</strong></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UpcomingEventViewModel" Property="Title" Title="Event" />
            </Columns>
        </RadzenDataGrid>
    </div>
}

<!-- Positionen -->
<div class="section">
    <h2>Offene Positionen</h2>
    @if (vm.Positions.Any())
    {
        <RadzenDataGrid Data="@vm.Positions" TItem="Position" Density="Density.Compact" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="Position" Property="Symbol" Title="Symbol" Width="120px">
                    <Template Context="p"><strong>@p.Symbol</strong></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Position" Property="Side" Title="Side" Width="80px">
                    <Template Context="p">
                        <span class="@(p.Side == "buy" ? "pnl-positive" : "pnl-negative")">@p.Side.ToUpper()</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Position" Property="Quantity" Title="Menge (Lots)" Width="120px">
                    <Template Context="p">@p.Quantity.ToString("F2")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Position" Property="AveragePrice" Title="Avg Preis" Width="120px">
                    <Template Context="p">$@p.AveragePrice.ToString("F4")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Position" Property="CurrentPrice" Title="Aktuell" Width="120px">
                    <Template Context="p">$@p.CurrentPrice.ToString("F4")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Position" Property="UnrealizedPnL" Title="P&L" Width="120px">
                    <Template Context="p">
                        <span class="@(p.UnrealizedPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                            @(p.UnrealizedPnL >= 0 ? "+" : "")$@p.UnrealizedPnL.ToString("F2")
                        </span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Position" Property="UnrealizedPnLPercent" Title="P&L %" Width="100px">
                    <Template Context="p">
                        <span class="@(p.UnrealizedPnLPercent >= 0 ? "pnl-positive" : "pnl-negative")">
                            @(p.UnrealizedPnLPercent >= 0 ? "+" : "")@p.UnrealizedPnLPercent.ToString("F2")%
                        </span>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
    else
    {
        <div class="empty-state">Keine offenen Positionen</div>
    }
</div>

<!-- Letzte Trades -->
<div class="section">
    <h2>Letzte Trades</h2>
    @if (vm.RecentTrades.Any())
    {
        <RadzenDataGrid Data="@vm.RecentTrades" TItem="Trade" Density="Density.Compact" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="Trade" Property="CreatedAt" Title="Zeit" Width="130px">
                    <Template Context="t">
                        <span style="font-size:0.75rem;color:var(--muted)">@LocalTime.Short(t.CreatedAt)</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Trade" Property="Symbol" Title="Symbol" Width="100px">
                    <Template Context="t"><strong>@t.Symbol</strong></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Trade" Property="Action" Title="Aktion" Width="80px">
                    <Template Context="t">
                        <span class="@(t.Action == TradeAction.Buy ? "pnl-positive" : "pnl-negative")">@t.Action.ToString().ToUpper()</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Trade" Property="Quantity" Title="Menge" Width="80px">
                    <Template Context="t">@t.Quantity.ToString("F2")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Trade" Property="Price" Title="Preis" Width="100px">
                    <Template Context="t">$@t.Price.ToString("F4")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Trade" Property="ClaudeConfidence" Title="Confidence" Width="100px">
                    <Template Context="t">@t.ClaudeConfidence.ToString("P0")</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Trade" Title="Status" Width="120px" Sortable="false">
                    <Template Context="t"><TradeStatusBadge Status="t.Status" ErrorMessage="@t.ErrorMessage" /></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Trade" Title="Begruendung" Sortable="false">
                    <Template Context="t"><ReasoningCell ErrorMessage="@t.ErrorMessage" Reasoning="@t.ClaudeReasoning" /></Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
    else
    {
        <div class="empty-state">Noch keine Trades</div>
    }
</div>

<!-- Logs -->
<div class="section">
    <h2>Letzte Log-Eintraege</h2>
    @if (vm.RecentLogs.Any())
    {
        <RadzenDataGrid Data="@vm.RecentLogs" TItem="TradingLog" Density="Density.Compact">
            <Columns>
                <RadzenDataGridColumn TItem="TradingLog" Property="Timestamp" Title="Zeit" Width="100px">
                    <Template Context="log">
                        <span class="log-time">@log.Timestamp.ToString("HH:mm:ss")</span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="TradingLog" Property="Source" Title="Quelle" Width="140px" />
                <RadzenDataGridColumn TItem="TradingLog" Property="Message" Title="Nachricht">
                    <Template Context="log">
                        @{
                            var cls = log.Level switch
                            {
                                "Warning" => "log-warn",
                                "Error" or "Critical" => "log-error",
                                _ => ""
                            };
                        }
                        <span class="@cls">@log.Message</span>
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
    else
    {
        <div class="empty-state">Keine Log-Eintraege</div>
    }
</div>

} @* end else HasAccounts *@

@code {
    private DashboardViewModel vm = new();
    private HubConnection? _hubConnection;
    private string _selectedAccountId = "default";
    private bool _dataLoaded;

    private AccountContext? SelectedAccount => AccountMgr.GetAccount(_selectedAccountId);

    protected override async Task OnInitializedAsync()
    {
        _selectedAccountId = AccountMgr.DefaultAccount?.AccountId ?? "default";

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/tradinghub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<DashboardViewModel>(TradingHub.DashboardUpdate, update =>
        {
            // Nur Updates fuer den ausgewaehlten Account anzeigen
            if (update.AccountId == _selectedAccountId)
            {
                vm = update;
                InvokeAsync(StateHasChanged);
            }
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch (Exception)
        {
            // Hub nicht verfuegbar, Fallback auf initiale Daten
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_dataLoaded)
        {
            _dataLoaded = true;
            try
            {
                await LoadDataAsync();
                StateHasChanged();
            }
            catch (Exception)
            {
                // SignalR liefert Updates als Fallback
            }
        }
    }

    private async Task OnAccountChanged()
    {
        await LoadDataAsync();
        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        var ctx = SelectedAccount;
        if (ctx == null) return;

        var positions = new List<Position>();
        decimal cash = 0, portfolioValue = 0;
        var account = new AccountDetails();

        try
        {
            positions = await ctx.EffectiveBroker.GetPositionsAsync();
            account = await ctx.EffectiveBroker.GetAccountDetailsAsync();
            cash = account.FreeMargin > 0 ? account.FreeMargin : account.Balance;
            portfolioValue = account.Equity > 0 ? account.Equity : account.Balance;
        }
        catch { }

        await using var db = await DbFactory.CreateDbContextAsync();
        var aid = _selectedAccountId;

        var todayStart = DateTime.UtcNow.Date;
        var tradesToday = await db.Trades
            .Where(t => t.AccountId == aid && t.CreatedAt >= todayStart)
            .CountAsync();

        var recentTrades = await db.Trades
            .Where(t => t.AccountId == aid)
            .OrderByDescending(t => t.CreatedAt)
            .Take(20)
            .ToListAsync();

        var recentLogs = await db.TradingLogs
            .Where(l => l.AccountId == aid)
            .OrderByDescending(l => l.Timestamp)
            .Take(30)
            .ToListAsync();

        var pnlHistory = await db.DailyPnLs
            .Where(d => d.AccountId == aid)
            .OrderByDescending(d => d.Date)
            .Take(30)
            .ToListAsync();

        var stats = await TradingStatsService.CalculateFromDbAsync(db, pnlHistory);

        vm = new DashboardViewModel
        {
            AccountId = aid,
            AccountDisplayName = ctx.DisplayName,
            PortfolioValue = portfolioValue,
            AvailableCash = cash,
            Account = account,
            OpenPositions = positions.Count,
            TradesToday = tradesToday,
            IsEngineRunning = ctx.Engine.IsRunning,
            IsEnginePaused = ctx.Engine.IsPaused,
            IsKillSwitchActive = ctx.Risk.IsKillSwitchActive,
            IsTradeLockerConnected = ctx.EffectiveBroker.IsConnected,
            IsMarketOpen = MarketHours.IsMarketOpen(),
            IsPaperTrading = ctx.PaperTrading.IsPaperTradingActive,
            MarketStatus = MarketHours.GetMarketStatus(),
            UpcomingEvents = Calendar.GetUpcomingHighImpactEvents(5)
                .Select(e => new UpcomingEventViewModel
                {
                    Title = e.Title,
                    EventTime = e.EventTime,
                    Impact = e.Impact.ToString(),
                    Currency = e.Currency
                }).ToList(),
            Positions = positions,
            RecentTrades = recentTrades,
            RecentLogs = recentLogs,
            PnLHistory = pnlHistory,
            Stats = stats
        };
    }

    private void PauseEngine()
    {
        SelectedAccount?.Engine.Pause();
        vm = vm with { IsEnginePaused = true };
    }

    private void ResumeEngine()
    {
        SelectedAccount?.Engine.Resume();
        vm = vm with { IsEnginePaused = false };
    }

    private async Task ActivateKillSwitch()
    {
        var confirmed = await DialogService.Confirm(
            "Kill Switch aktivieren? Alle Trading-Aktivitaeten werden sofort gestoppt. Offene Positionen bleiben bestehen.",
            "Kill Switch aktivieren",
            new ConfirmOptions { OkButtonText = "Aktivieren", CancelButtonText = "Abbrechen" });

        if (confirmed != true) return;

        SelectedAccount?.Risk.ActivateKillSwitch("Manuell via Dashboard aktiviert");
        vm = vm with { IsKillSwitchActive = true, IsEnginePaused = false };
    }

    private async Task ResetKillSwitch()
    {
        var confirmed = await DialogService.Confirm(
            "Kill Switch zuruecksetzen? Der Trading Bot wird wieder Trades ausfuehren.",
            "Kill Switch zuruecksetzen",
            new ConfirmOptions { OkButtonText = "Zuruecksetzen", CancelButtonText = "Abbrechen" });

        if (confirmed != true) return;

        SelectedAccount?.Risk.ResetKillSwitch();
        vm = vm with { IsKillSwitchActive = false };
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
