@page "/"
@using ClaudeTradingBot.Data
@using ClaudeTradingBot.Hubs
@using Microsoft.EntityFrameworkCore
@inject AccountManager AccountMgr
@inject MarketHoursService MarketHours
@inject EconomicCalendarService Calendar
@inject IDbContextFactory<TradingDbContext> DbFactory
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Dashboard - Claude Trading Bot</PageTitle>

@if (AccountMgr.Accounts.Count > 1)
{
    <div style="margin-bottom: 12px;">
        <label style="margin-right: 8px;">Account:</label>
        <select value="@_selectedAccountId" @onchange="OnAccountChanged" style="padding: 4px 8px; background: var(--card-bg, #1e1e2e); color: var(--text, #cdd6f4); border: 1px solid var(--border, #45475a); border-radius: 4px;">
            @foreach (var acc in AccountMgr.Accounts)
            {
                <option value="@acc.AccountId">@acc.DisplayName (@acc.AccountId)</option>
            }
        </select>
    </div>
}

<div class="status-badges" style="margin-bottom: 24px;">
    @{ var engineText = vm.IsEnginePaused ? "Engine Pausiert" : vm.IsEngineRunning ? "Engine Laeuft" : "Engine Wartet"; }
    @{ var engineColor = vm.IsEnginePaused ? "red" : vm.IsEngineRunning ? "green" : "yellow"; }
    <StatusBadge Text="@engineText" Color="@engineColor" />
    <StatusBadge Text="@(vm.IsTradeLockerConnected ? "TradeLocker Verbunden" : "TradeLocker Getrennt")"
                 Color="@(vm.IsTradeLockerConnected ? "green" : "red")" />
    @if (vm.IsPaperTrading)
    {
        <StatusBadge Text="Paper-Trading Aktiv" Color="yellow" />
    }
    @if (vm.IsKillSwitchActive)
    {
        <StatusBadge Text="Kill Switch Aktiv" Color="red" />
    }
    <StatusBadge Text="@($"Markt {vm.MarketStatus}")"
                 Color="@(vm.IsMarketOpen ? "green" : "red")" />
</div>

<!-- Konto-Uebersicht -->
<div class="stats-grid">
    <StatCard Label="Eigenkapital (Equity)" Value="@($"${vm.Account.Equity:N2}")" />
    <StatCard Label="Kontostand (Balance)" Value="@($"${vm.Account.Balance:N2}")" />
    <StatCard Label="Unrealisierter P&L"
              Value="@($"{(vm.Account.UnrealizedPnL >= 0 ? "+" : "")}${vm.Account.UnrealizedPnL:N2}")"
              CssClass="@(vm.Account.UnrealizedPnL >= 0 ? "stat-positive" : "stat-negative")" />
    <StatCard Label="Verwendete Margin" Value="@($"${vm.Account.Margin:N2}")" />
    <StatCard Label="Verfuegbare Margin" Value="@($"${vm.Account.FreeMargin:N2}")" />
    @if (vm.Account.Margin > 0)
    {
        <StatCard Label="Margin-Nutzung"
                  Value="@($"{vm.Account.MarginUsagePercent:F2}%")"
                  CssClass="@(vm.Account.MarginUsagePercent <= 50 ? "stat-positive" : vm.Account.MarginUsagePercent <= 80 ? "" : "stat-negative")" />
    }
    <StatCard Label="Offene Positionen" Value="@vm.OpenPositions.ToString()" />
    <StatCard Label="Trades Heute" Value="@vm.TradesToday.ToString()" />
</div>

<!-- Controls -->
<div class="controls">
    @if (vm.IsEnginePaused)
    {
        <button class="btn btn-primary" @onclick="ResumeEngine">Engine Starten</button>
    }
    else
    {
        <button class="btn btn-outline" @onclick="PauseEngine">Engine Pausieren</button>
    }
    <button class="btn btn-danger" @onclick="ActivateKillSwitch">Kill Switch</button>
    @if (vm.IsKillSwitchActive)
    {
        <button class="btn btn-success" @onclick="ResetKillSwitch">Kill Switch Reset</button>
    }
</div>

<!-- Equity-Kurve -->
<EquityChart PnLHistory="vm.PnLHistory" />

<!-- Performance-Statistiken -->
<TradingStats Stats="vm.Stats" />

<!-- Naechste High-Impact Events -->
@if (vm.UpcomingEvents.Any())
{
    <div class="section">
        <h2>Naechste High-Impact Events</h2>
        <table>
            <thead>
                <tr><th>Zeit (UTC)</th><th>Waehrung</th><th>Event</th></tr>
            </thead>
            <tbody>
                @foreach (var evt in vm.UpcomingEvents)
                {
                    <tr>
                        <td>@evt.EventTime.ToString("dd.MM. HH:mm")</td>
                        <td><strong>@evt.Currency</strong></td>
                        <td>@evt.Title</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Positionen -->
<div class="section">
    <h2>Offene Positionen</h2>
    @if (vm.Positions.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Symbol</th><th>Side</th><th>Menge (Lots)</th><th>Avg Preis</th>
                    <th>Aktuell</th><th>P&amp;L</th><th>P&amp;L %</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in vm.Positions)
                {
                    <tr>
                        <td><strong>@p.Symbol</strong></td>
                        <td class="@(p.Side == "buy" ? "pnl-positive" : "pnl-negative")">
                            @p.Side.ToUpper()
                        </td>
                        <td>@p.Quantity.ToString("F2")</td>
                        <td>$@p.AveragePrice.ToString("F4")</td>
                        <td>$@p.CurrentPrice.ToString("F4")</td>
                        <td class="@(p.UnrealizedPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                            @(p.UnrealizedPnL >= 0 ? "+" : "")$@p.UnrealizedPnL.ToString("F2")
                        </td>
                        <td class="@(p.UnrealizedPnLPercent >= 0 ? "pnl-positive" : "pnl-negative")">
                            @(p.UnrealizedPnLPercent >= 0 ? "+" : "")@p.UnrealizedPnLPercent.ToString("F2")%
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">Keine offenen Positionen</div>
    }
</div>

<!-- Letzte Trades -->
<div class="section">
    <h2>Letzte Trades</h2>
    @if (vm.RecentTrades.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Zeit</th><th>Symbol</th><th>Aktion</th>
                    <th>Menge</th><th>Preis</th><th>Confidence</th>
                    <th>Status</th><th>Begruendung</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in vm.RecentTrades)
                {
                    <tr>
                        <td style="font-size:0.75rem;color:var(--muted)">@t.CreatedAt.ToString("dd.MM HH:mm")</td>
                        <td><strong>@t.Symbol</strong></td>
                        <td class="@(t.Action == TradeAction.Buy ? "pnl-positive" : "pnl-negative")">
                            @t.Action.ToString().ToUpper()
                        </td>
                        <td>@t.Quantity.ToString("F2")</td>
                        <td>$@t.Price.ToString("F4")</td>
                        <td>@t.ClaudeConfidence.ToString("P0")</td>
                        <td><TradeStatusBadge Status="t.Status" ErrorMessage="@t.ErrorMessage" /></td>
                        <td><ReasoningCell ErrorMessage="@t.ErrorMessage" Reasoning="@t.ClaudeReasoning" /></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">Noch keine Trades</div>
    }
</div>

<!-- Logs -->
<div class="section">
    <h2>Letzte Log-Eintraege</h2>
    @if (vm.RecentLogs.Any())
    {
        <table>
            <thead><tr><th>Zeit</th><th>Quelle</th><th>Nachricht</th></tr></thead>
            <tbody>
                @foreach (var log in vm.RecentLogs)
                {
                    var cls = log.Level switch
                    {
                        "Warning" => "log-warn",
                        "Error" or "Critical" => "log-error",
                        _ => ""
                    };
                    <tr class="log-entry">
                        <td class="log-time">@log.Timestamp.ToString("HH:mm:ss")</td>
                        <td>@log.Source</td>
                        <td class="@cls">@log.Message</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">Keine Log-Eintraege</div>
    }
</div>

@code {
    private DashboardViewModel vm = new();
    private HubConnection? _hubConnection;
    private string _selectedAccountId = "default";
    private bool _dataLoaded;

    private AccountContext SelectedAccount => AccountMgr.GetAccount(_selectedAccountId);

    protected override async Task OnInitializedAsync()
    {
        _selectedAccountId = AccountMgr.DefaultAccount.AccountId;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/tradinghub"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<DashboardViewModel>(TradingHub.DashboardUpdate, update =>
        {
            // Nur Updates fuer den ausgewaehlten Account anzeigen
            if (update.AccountId == _selectedAccountId)
            {
                vm = update;
                InvokeAsync(StateHasChanged);
            }
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch (Exception)
        {
            // Hub nicht verfuegbar, Fallback auf initiale Daten
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_dataLoaded)
        {
            _dataLoaded = true;
            try
            {
                await LoadDataAsync();
                StateHasChanged();
            }
            catch (Exception)
            {
                // SignalR liefert Updates als Fallback
            }
        }
    }

    private async Task OnAccountChanged(ChangeEventArgs e)
    {
        _selectedAccountId = e.Value?.ToString() ?? AccountMgr.DefaultAccount.AccountId;
        await LoadDataAsync();
        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        var ctx = SelectedAccount;
        var positions = new List<Position>();
        decimal cash = 0, portfolioValue = 0;
        var account = new AccountDetails();

        try
        {
            positions = await ctx.EffectiveBroker.GetPositionsAsync();
            account = await ctx.EffectiveBroker.GetAccountDetailsAsync();
            cash = account.FreeMargin > 0 ? account.FreeMargin : account.Balance;
            portfolioValue = account.Equity > 0 ? account.Equity : account.Balance;
        }
        catch { }

        await using var db = await DbFactory.CreateDbContextAsync();
        var aid = _selectedAccountId;

        var todayStart = DateTime.UtcNow.Date;
        var tradesToday = await db.Trades
            .Where(t => t.AccountId == aid && t.CreatedAt >= todayStart)
            .CountAsync();

        var recentTrades = await db.Trades
            .Where(t => t.AccountId == aid)
            .OrderByDescending(t => t.CreatedAt)
            .Take(20)
            .ToListAsync();

        var recentLogs = await db.TradingLogs
            .Where(l => l.AccountId == aid)
            .OrderByDescending(l => l.Timestamp)
            .Take(30)
            .ToListAsync();

        var pnlHistory = await db.DailyPnLs
            .Where(d => d.AccountId == aid)
            .OrderByDescending(d => d.Date)
            .Take(30)
            .ToListAsync();

        var stats = await TradingStatsService.CalculateFromDbAsync(db, pnlHistory);

        vm = new DashboardViewModel
        {
            AccountId = aid,
            AccountDisplayName = ctx.DisplayName,
            PortfolioValue = portfolioValue,
            AvailableCash = cash,
            Account = account,
            OpenPositions = positions.Count,
            TradesToday = tradesToday,
            IsEngineRunning = ctx.Engine.IsRunning,
            IsEnginePaused = ctx.Engine.IsPaused,
            IsKillSwitchActive = ctx.Risk.IsKillSwitchActive,
            IsTradeLockerConnected = ctx.EffectiveBroker.IsConnected,
            IsMarketOpen = MarketHours.IsMarketOpen(),
            IsPaperTrading = ctx.PaperTrading.IsPaperTradingActive,
            MarketStatus = MarketHours.GetMarketStatus(),
            UpcomingEvents = Calendar.GetUpcomingHighImpactEvents(5)
                .Select(e => new UpcomingEventViewModel
                {
                    Title = e.Title,
                    EventTime = e.EventTime,
                    Impact = e.Impact.ToString(),
                    Currency = e.Currency
                }).ToList(),
            Positions = positions,
            RecentTrades = recentTrades,
            RecentLogs = recentLogs,
            PnLHistory = pnlHistory,
            Stats = stats
        };
    }

    private void PauseEngine()
    {
        SelectedAccount.Engine.Pause();
        vm = vm with { IsEnginePaused = true };
    }

    private void ResumeEngine()
    {
        SelectedAccount.Engine.Resume();
        vm = vm with { IsEnginePaused = false };
    }

    private void ActivateKillSwitch()
    {
        SelectedAccount.Risk.ActivateKillSwitch("Manuell via Dashboard aktiviert");
        vm = vm with { IsKillSwitchActive = true, IsEnginePaused = false };
    }

    private void ResetKillSwitch()
    {
        SelectedAccount.Risk.ResetKillSwitch();
        vm = vm with { IsKillSwitchActive = false };
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
            await _hubConnection.DisposeAsync();
    }
}
