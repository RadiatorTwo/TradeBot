@page "/journal"
@using ClaudeTradingBot.Data
@using ClaudeTradingBot.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<TradingDbContext> DbFactory

<PageTitle>Trade-Journal - Claude Trading Bot</PageTitle>

<h2 style="margin-bottom: 24px;">Trade-Journal</h2>

<!-- Filter -->
<RadzenStack Orientation="Orientation.Horizontal" Gap="12px" Style="margin-bottom: 24px;" Wrap="FlexWrap.Wrap" AlignItems="AlignItems.End">
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Von" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDatePicker @bind-Value="_filterFrom" DateFormat="dd.MM.yyyy" />
    </RadzenStack>
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Bis" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDatePicker @bind-Value="_filterTo" DateFormat="dd.MM.yyyy" />
    </RadzenStack>
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Symbol" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDropDown @bind-Value="_filterSymbol" Data="_symbolOptions" TextProperty="Text" ValueProperty="Value" Style="min-width: 140px;" />
    </RadzenStack>
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Setup-Typ" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDropDown @bind-Value="_filterSetupType" Data="_setupTypeOptions" TextProperty="Text" ValueProperty="Value" Style="min-width: 140px;" />
    </RadzenStack>
    <RadzenStack Gap="4px">
        <RadzenLabel Text="Status" Style="font-size: 0.75rem; color: var(--muted); text-transform: uppercase;" />
        <RadzenDropDown @bind-Value="_filterStatus" Data="_statusOptions" TextProperty="Text" ValueProperty="Value" Style="min-width: 140px;" />
    </RadzenStack>
    <RadzenButton Text="Filtern" ButtonStyle="ButtonStyle.Primary" Click="@ApplyFilter" />
</RadzenStack>

<!-- Per-SetupType Performance -->
@if (_setupStats.Count > 0)
{
    <div class="section" style="margin-bottom: 24px;">
        <h3>Performance pro Setup-Typ</h3>
        <RadzenDataGrid Data="@_setupStats" TItem="SetupTypeStatsViewModel" Density="Density.Compact" AllowSorting="true">
            <Columns>
                <RadzenDataGridColumn TItem="SetupTypeStatsViewModel" Property="SetupType" Title="Setup-Typ" Width="160px">
                    <Template Context="s"><strong>@s.SetupType</strong></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SetupTypeStatsViewModel" Property="TradeCount" Title="Trades" Width="80px" />
                <RadzenDataGridColumn TItem="SetupTypeStatsViewModel" Property="WinRate" Title="Win-Rate" Width="100px">
                    <Template Context="s">@s.WinRate.ToString("F1")%</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SetupTypeStatsViewModel" Property="TotalPnL" Title="PnL" Width="120px">
                    <Template Context="s">
                        <span class="@(s.TotalPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                            @(s.TotalPnL >= 0 ? "+" : "")$@s.TotalPnL.ToString("F2")
                        </span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SetupTypeStatsViewModel" Property="AvgPnL" Title="Avg PnL" Width="120px">
                    <Template Context="s">
                        <span class="@(s.AvgPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                            @(s.AvgPnL >= 0 ? "+" : "")$@s.AvgPnL.ToString("F2")
                        </span>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="SetupTypeStatsViewModel" Property="ProfitFactor" Title="Profit-Faktor" Width="120px">
                    <Template Context="s">@s.ProfitFactor.ToString("F2")</Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    </div>
}

<!-- Trade-Liste -->
@if (_trades.Count > 0)
{
    <RadzenDataGrid Data="@_trades" TItem="Trade" Density="Density.Compact" AllowSorting="true">
        <Columns>
            <RadzenDataGridColumn TItem="Trade" Property="CreatedAt" Title="Zeit" Width="150px">
                <Template Context="t">
                    <span style="font-size:0.75rem;color:var(--muted)">@t.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Symbol" Title="Symbol" Width="100px">
                <Template Context="t"><strong>@t.Symbol</strong></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Action" Title="Aktion" Width="80px">
                <Template Context="t">
                    <span class="@(t.Action == TradeAction.Buy ? "pnl-positive" : "pnl-negative")">@t.Action.ToString().ToUpper()</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="SetupType" Title="Setup" Width="100px">
                <Template Context="t"><span style="font-size:0.8rem;">@(t.SetupType ?? "—")</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Quantity" Title="Menge" Width="80px">
                <Template Context="t">@t.Quantity.ToString("F2")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Price" Title="Preis" Width="100px">
                <Template Context="t">$@t.Price.ToString("F4")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="RealizedPnL" Title="PnL" Width="100px">
                <Template Context="t">
                    @if (t.RealizedPnL.HasValue)
                    {
                        <span class="@(t.RealizedPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                            @($"{(t.RealizedPnL >= 0 ? "+" : "")}${t.RealizedPnL:F2}")
                        </span>
                    }
                    else
                    {
                        <span style="color:var(--muted)">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="ClaudeConfidence" Title="Confidence" Width="100px">
                <Template Context="t">@t.ClaudeConfidence.ToString("P0")</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Property="Tags" Title="Tags" Width="140px">
                <Template Context="t">
                    <span style="font-size:0.75rem;color:var(--muted);max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;display:block;">
                        @(t.Tags ?? "")
                    </span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Title="Status" Width="120px" Sortable="false">
                <Template Context="t"><TradeStatusBadge Status="t.Status" ErrorMessage="@t.ErrorMessage" /></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Trade" Title="" Width="70px" Sortable="false">
                <Template Context="t"><a href="/journal/@t.Id" style="color:var(--blue, #89b4fa);font-size:0.8rem;">Details</a></Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}
else
{
    <div class="empty-state">Keine Trades gefunden</div>
}

@code {
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private string _filterSymbol = string.Empty;
    private string _filterSetupType = string.Empty;
    private string _filterStatus = string.Empty;

    private List<Trade> _trades = new();
    private List<string> _availableSymbols = new();
    private List<string> _availableSetupTypes = new();
    private List<SetupTypeStatsViewModel> _setupStats = new();

    private record DropDownItem(string Text, string Value);

    private List<DropDownItem> _symbolOptions = new() { new("Alle", "") };
    private List<DropDownItem> _setupTypeOptions = new() { new("Alle", "") };
    private List<DropDownItem> _statusOptions = new()
    {
        new("Alle", ""),
        new("Ausgefuehrt", "Executed"),
        new("Abgelehnt", "Rejected")
    };

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _availableSymbols = await db.Trades
            .Select(t => t.Symbol).Distinct().OrderBy(s => s).ToListAsync();

        _availableSetupTypes = await db.Trades
            .Where(t => t.SetupType != null)
            .Select(t => t.SetupType!).Distinct().OrderBy(s => s).ToListAsync();

        _symbolOptions = new List<DropDownItem> { new("Alle", "") };
        _symbolOptions.AddRange(_availableSymbols.Select(s => new DropDownItem(s, s)));

        _setupTypeOptions = new List<DropDownItem> { new("Alle", "") };
        _setupTypeOptions.AddRange(_availableSetupTypes.Select(s => new DropDownItem(s, s)));

        _setupStats = await TradingStatsService.CalculatePerSetupTypeAsync(db);

        await ApplyFilter();
    }

    private async Task ApplyFilter()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.Trades.AsQueryable();

        if (_filterFrom.HasValue)
            query = query.Where(t => t.CreatedAt >= _filterFrom.Value);
        if (_filterTo.HasValue)
            query = query.Where(t => t.CreatedAt <= _filterTo.Value.Date.AddDays(1));
        if (!string.IsNullOrEmpty(_filterSymbol))
            query = query.Where(t => t.Symbol == _filterSymbol);
        if (!string.IsNullOrEmpty(_filterSetupType))
            query = query.Where(t => t.SetupType == _filterSetupType);
        if (!string.IsNullOrEmpty(_filterStatus) && Enum.TryParse<TradeStatus>(_filterStatus, out var status))
            query = query.Where(t => t.Status == status);

        _trades = await query
            .OrderByDescending(t => t.CreatedAt)
            .Take(500)
            .ToListAsync();
    }
}
