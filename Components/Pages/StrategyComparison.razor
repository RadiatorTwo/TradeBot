@page "/strategies"
@using ClaudeTradingBot.Data
@using Microsoft.EntityFrameworkCore
@inject AccountManager AccountMgr
@inject IDbContextFactory<TradingDbContext> DbFactory

<PageTitle>Strategie-Vergleich - NeuronTrade</PageTitle>

<h2 style="margin-bottom: 24px;">Strategie-Vergleich</h2>

@if (!AccountMgr.HasAccounts)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" AllowClose="false">
        Kein Account konfiguriert. Bitte unter <a href="/accounts">Accounts</a> einen Account anlegen.
    </RadzenAlert>
}
else if (_stats.Count < 2)
{
    <RadzenAlert AlertStyle="AlertStyle.Info" AllowClose="false">
        Mindestens 2 Accounts noetig fuer den Vergleich. Aktuell: @_stats.Count Account(s).
        Weitere Accounts unter <a href="/accounts">Accounts</a> anlegen.
    </RadzenAlert>
}
else
{
    <div style="display: grid; grid-template-columns: repeat(@Math.Min(_stats.Count, 3), 1fr); gap: 16px; margin-bottom: 24px;">
        @foreach (var s in _stats)
        {
            var isWinner = _stats.Count > 1 && s.NetPnL == _stats.Max(x => x.NetPnL) && s.NetPnL != 0;
            <RadzenCard Style="@($"border: 1px solid {(isWinner ? "var(--green)" : "var(--border)")}; padding: 16px;")">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                    <div>
                        <strong style="font-size: 1.1rem;">@s.DisplayName</strong>
                        @if (!string.IsNullOrEmpty(s.StrategyLabel))
                        {
                            <RadzenBadge Text="@s.StrategyLabel" BadgeStyle="BadgeStyle.Info" />
                        }
                    </div>
                    @if (isWinner)
                    {
                        <RadzenBadge Text="FUEHREND" BadgeStyle="BadgeStyle.Success" />
                    }
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-size: 0.9rem;">
                    <div>
                        <div style="color: var(--muted);">Netto-PnL</div>
                        <strong style="font-size: 1.2rem;" class="@(s.NetPnL >= 0 ? "pnl-positive" : "pnl-negative")">
                            @(s.NetPnL >= 0 ? "+" : "")$@s.NetPnL.ToString("N2")
                        </strong>
                    </div>
                    <div>
                        <div style="color: var(--muted);">Win-Rate</div>
                        <strong style="font-size: 1.2rem;">@s.WinRate.ToString("F1")%</strong>
                    </div>
                    <div>
                        <div style="color: var(--muted);">Trades</div>
                        <strong>@s.TotalTrades</strong>
                    </div>
                    <div>
                        <div style="color: var(--muted);">Profit Factor</div>
                        <strong>@s.ProfitFactor.ToString("F2")</strong>
                    </div>
                    <div>
                        <div style="color: var(--muted);">Avg. Win</div>
                        <strong class="pnl-positive">+$@s.AvgWin.ToString("N2")</strong>
                    </div>
                    <div>
                        <div style="color: var(--muted);">Avg. Loss</div>
                        <strong class="pnl-negative">-$@s.AvgLoss.ToString("N2")</strong>
                    </div>
                    <div>
                        <div style="color: var(--muted);">Max Drawdown</div>
                        <strong>@s.MaxDrawdownPercent.ToString("F1")%</strong>
                    </div>
                    <div>
                        <div style="color: var(--muted);">Sharpe Ratio</div>
                        <strong>@s.SharpeRatio.ToString("F2")</strong>
                    </div>
                </div>

                <div style="margin-top: 12px; padding-top: 8px; border-top: 1px solid var(--border); font-size: 0.8rem; color: var(--muted);">
                    Watchlist: @string.Join(", ", s.WatchList)
                </div>
            </RadzenCard>
        }
    </div>

    @* Detaillierte Vergleichstabelle *@
    <div class="section">
        <h3>Detailvergleich</h3>
        <table>
            <thead>
                <tr>
                    <th>Kennzahl</th>
                    @foreach (var s in _stats)
                    {
                        <th>@s.DisplayName</th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Netto-PnL</td>
                    @foreach (var s in _stats)
                    {
                        <td class="@(s.NetPnL >= 0 ? "pnl-positive" : "pnl-negative")">@(s.NetPnL >= 0 ? "+" : "")$@s.NetPnL.ToString("N2")</td>
                    }
                </tr>
                <tr><td>Gewinn (brutto)</td>@foreach (var s in _stats) { <td>$@s.TotalProfit.ToString("N2")</td> }</tr>
                <tr><td>Verlust (brutto)</td>@foreach (var s in _stats) { <td>$@s.TotalLoss.ToString("N2")</td> }</tr>
                <tr><td>Win-Rate</td>@foreach (var s in _stats) { <td>@s.WinRate.ToString("F1")%</td> }</tr>
                <tr><td>Profit Factor</td>@foreach (var s in _stats) { <td>@s.ProfitFactor.ToString("F2")</td> }</tr>
                <tr><td>Trades gesamt</td>@foreach (var s in _stats) { <td>@s.TotalTrades</td> }</tr>
                <tr><td>Davon gewonnen</td>@foreach (var s in _stats) { <td>@s.WinningTrades</td> }</tr>
                <tr><td>Davon verloren</td>@foreach (var s in _stats) { <td>@s.LosingTrades</td> }</tr>
                <tr><td>Avg. Win</td>@foreach (var s in _stats) { <td>$@s.AvgWin.ToString("N2")</td> }</tr>
                <tr><td>Avg. Loss</td>@foreach (var s in _stats) { <td>$@s.AvgLoss.ToString("N2")</td> }</tr>
                <tr><td>Max Drawdown</td>@foreach (var s in _stats) { <td>@s.MaxDrawdownPercent.ToString("F1")%</td> }</tr>
                <tr><td>Sharpe Ratio</td>@foreach (var s in _stats) { <td>@s.SharpeRatio.ToString("F2")</td> }</tr>
                <tr><td>Trades/Tag</td>@foreach (var s in _stats) { <td>@s.TradesPerDay.ToString("F1")</td> }</tr>
                <tr><td>Avg. Confidence</td>@foreach (var s in _stats) { <td>@s.AvgConfidence.ToString("F1")%</td> }</tr>
            </tbody>
        </table>
    </div>
}

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private record StrategyStats
    {
        public string AccountId { get; init; } = string.Empty;
        public string DisplayName { get; init; } = string.Empty;
        public string StrategyLabel { get; init; } = string.Empty;
        public string[] WatchList { get; init; } = Array.Empty<string>();
        public decimal NetPnL { get; init; }
        public decimal TotalProfit { get; init; }
        public decimal TotalLoss { get; init; }
        public double WinRate { get; init; }
        public decimal ProfitFactor { get; init; }
        public int TotalTrades { get; init; }
        public int WinningTrades { get; init; }
        public int LosingTrades { get; init; }
        public decimal AvgWin { get; init; }
        public decimal AvgLoss { get; init; }
        public double MaxDrawdownPercent { get; init; }
        public double SharpeRatio { get; init; }
        public double TradesPerDay { get; init; }
        public double AvgConfidence { get; init; }
    }

    private List<StrategyStats> _stats = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadStatsAsync();
            StateHasChanged();
        }
    }

    private async Task LoadStatsAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        foreach (var ctx in AccountMgr.Accounts)
        {
            var aid = ctx.AccountId;

            var pnlHistory = await db.DailyPnLs
                .Where(d => d.AccountId == aid)
                .OrderByDescending(d => d.Date)
                .Take(30)
                .ToListAsync();

            var stats = await TradingStatsService.CalculateFromDbAsync(db, pnlHistory);

            _stats.Add(new StrategyStats
            {
                AccountId = ctx.AccountId,
                DisplayName = ctx.DisplayName,
                StrategyLabel = ctx.StrategyLabel,
                WatchList = ctx.WatchList,
                NetPnL = stats.NetPnL,
                TotalProfit = stats.TotalProfit,
                TotalLoss = stats.TotalLoss,
                WinRate = stats.WinRate,
                ProfitFactor = stats.ProfitFactor,
                TotalTrades = stats.TotalExecuted,
                WinningTrades = stats.WinningTrades,
                LosingTrades = stats.LosingTrades,
                AvgWin = stats.AvgWin,
                AvgLoss = stats.AvgLoss,
                MaxDrawdownPercent = stats.MaxDrawdownPercent,
                SharpeRatio = stats.SharpeRatio,
                TradesPerDay = stats.TradesPerDay,
                AvgConfidence = stats.AvgConfidence
            });
        }
    }
}
