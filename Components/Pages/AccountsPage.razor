@page "/accounts"
@using ClaudeTradingBot.Models
@using ClaudeTradingBot.Services
@inject AccountManager AccountMgr
@inject ISettingsRepository SettingsRepo

<PageTitle>Accounts - NeuronTrade</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h2 style="margin: 0;">Accounts</h2>
    @if (!_showForm)
    {
        <RadzenButton Text="+ Neuer Account" ButtonStyle="ButtonStyle.Primary" Click="@ShowAddForm" />
    }
</div>

@if (_saveSuccess)
{
    <RadzenAlert AlertStyle="AlertStyle.Success" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="true" Style="margin-bottom: 24px;">
        Gespeichert. Aenderungen sind sofort aktiv.
    </RadzenAlert>
}

@if (_errors.Any())
{
    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false" Style="margin-bottom: 24px;">
        @foreach (var err in _errors)
        {
            <div>@err</div>
        }
    </RadzenAlert>
}

@* ── Formular (Hinzufuegen oder Bearbeiten) ─────────────────────────── *@
@if (_showForm)
{
    <RadzenCard Style="margin-bottom: 24px;">
        <h3 style="margin-top: 0;">@(_editMode ? $"\"{_editDisplayName}\" bearbeiten" : "Neuen Account anlegen")</h3>

        <EditForm Model="this" OnValidSubmit="SaveAccount" FormName="account-form">
            @* Schritt 1: Grunddaten *@
            <RadzenRow Gap="16px" Style="margin-bottom: 20px;">
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Kurzname (ID)" Style="display: block; margin-bottom: 4px;" />
                    <RadzenTextBox @bind-Value="_editId" Placeholder="Demo1" Style="width: 100%;" />
                    <div class="hint" style="margin-top: 4px;">Wird intern als Bezeichner verwendet. @(_editMode ? "Aendern erfordert Neustart." : "")</div>
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenLabel Text="Anzeigename" Style="display: block; margin-bottom: 4px;" />
                    <RadzenTextBox @bind-Value="_editDisplayName" Placeholder="Mein Demo-Konto" Style="width: 100%;" />
                </RadzenColumn>
            </RadzenRow>

            @* Schritt 2: Broker-Verbindung *@
            <details open="@(!_editMode)">
                <summary style="cursor: pointer; font-weight: 600; margin-bottom: 12px;">Broker-Verbindung (TradeLocker)</summary>
                <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="Server-URL" Style="display: block; margin-bottom: 4px;" />
                        <RadzenDropDown @bind-Value="_editBaseUrl" Data="_serverUrlOptions" TextProperty="Text" ValueProperty="Value" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="Server-Name" Style="display: block; margin-bottom: 4px;" />
                        <RadzenTextBox @bind-Value="_editServer" Placeholder="z.B. OSP-DEMO" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="Email" Style="display: block; margin-bottom: 4px;" />
                        <RadzenTextBox @bind-Value="_editEmail" Placeholder="deine@email.com" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="Passwort" Style="display: block; margin-bottom: 4px;" />
                        <RadzenPassword @bind-Value="_editPassword" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="TradeLocker Account-ID" Style="display: block; margin-bottom: 4px;" />
                        <RadzenTextBox @bind-Value="_editAccountId" Placeholder="z.B. 2005684 (leer = erster Account)" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Falls mehrere Broker-Accounts existieren, hier die gewuenschte Account-ID angeben. Leer = erster Account wird verwendet.</div>
                    </RadzenColumn>
                </RadzenRow>
            </details>

            @* Schritt 3: Paper-Trading *@
            <details>
                <summary style="cursor: pointer; font-weight: 600; margin-bottom: 12px;">Paper-Trading</summary>
                <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
                    <RadzenColumn Size="4">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                            <RadzenCheckBox @bind-Value="_editPaperEnabled" />
                            <RadzenLabel Text="Paper-Trading (kein echtes Geld)" />
                        </RadzenStack>
                        <div class="hint" style="margin-top: 4px;">Wenn aktiv werden keine echten Orders platziert.</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Paper-Startkapital ($)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="decimal" @bind-Value="_editPaperBalance" ShowUpDown="false" Min="100" Step="1000" Style="width: 100%;" />
                    </RadzenColumn>
                </RadzenRow>
            </details>

            @* Schritt 4: Risiko-Parameter *@
            <details>
                <summary style="cursor: pointer; font-weight: 600; margin-bottom: 12px;">Risiko-Parameter</summary>
                <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Min. Confidence" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMinConfidence" ShowUpDown="false" Min="0" Max="1" Step="0.05" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Minimale KI-Confidence (0-1)</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Risiko pro Trade (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editRiskPerTrade" ShowUpDown="false" Min="0" Max="10" Step="0.5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Position Sizing basierend auf SL-Distanz. 0 = LLM entscheidet Lotgroesse</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Positionsgroesse (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMaxPosSize" ShowUpDown="false" Min="1" Step="1" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. offene Positionen" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="int" @bind-Value="_editMaxOpenPos" ShowUpDown="false" Min="1" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Analyse-Intervall (Min.)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="int" @bind-Value="_editTradingInterval" ShowUpDown="false" Min="1" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Wie oft die Engine Marktdaten analysiert</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Spread (Pips)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMaxSpreadPips" ShowUpDown="false" Min="0" Step="0.5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Trade wird abgelehnt bei hoeherem Spread. 0 = deaktiviert</div>
                    </RadzenColumn>
                </RadzenRow>
            </details>

            @* Schritt 4b: Verlustlimits *@
            <details>
                <summary style="cursor: pointer; font-weight: 600; margin-bottom: 12px;">Verlustlimits</summary>
                <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Stop-Loss (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editStopLossPercent" ShowUpDown="false" Min="0" Step="0.5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Lokaler Stop-Loss pro Position (% vom Einstiegspreis)</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Tagesverlust (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMaxDailyLossPercent" ShowUpDown="false" Min="0" Step="0.5" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Tagesverlust ($)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="decimal" @bind-Value="_editMaxDailyLossAbsolute" ShowUpDown="false" Min="0" Step="50" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Wochenverlust (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMaxWeeklyLoss" ShowUpDown="false" Min="0" Step="1" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">0 = deaktiviert</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Monatsverlust (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMaxMonthlyLoss" ShowUpDown="false" Min="0" Step="1" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">0 = deaktiviert</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Drawdown vom Peak (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMaxDrawdown" ShowUpDown="false" Min="0" Step="1" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Kill Switch bei Ueberschreitung. 0 = deaktiviert</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. korrelierte Exposure (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editMaxCorrelatedExposure" ShowUpDown="false" Min="0" Step="5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Blockiert Trades bei hoher Korrelation. 0 = deaktiviert</div>
                    </RadzenColumn>
                </RadzenRow>
            </details>

            @* Schritt 4c: Gewinnschutz *@
            <details>
                <summary style="cursor: pointer; font-weight: 600; margin-bottom: 12px;">Gewinnschutz</summary>
                <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Trailing Stop (Pips)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editTrailingStop" ShowUpDown="false" Min="0" Step="5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">SL folgt dem Kurs im Gewinn. 0 = deaktiviert</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Breakeven ab (Pips)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editBreakevenTrigger" ShowUpDown="false" Min="0" Step="5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">SL auf Einstiegspreis bei X Pips Gewinn. 0 = deaktiviert</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Partial Close (%)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editPartialClosePercent" ShowUpDown="false" Min="0" Max="1" Step="0.1" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Anteil der Position der bei TP1 geschlossen wird (0-1). 0 = deaktiviert</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Partial Close ab (Pips)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editPartialCloseTrigger" ShowUpDown="false" Min="0" Step="5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Gewinn in Pips ab dem Partial Close ausgeloest wird</div>
                    </RadzenColumn>
                </RadzenRow>
            </details>

            @* Schritt 5: Grid-Trading *@
            <details>
                <summary style="cursor: pointer; font-weight: 600; margin-bottom: 12px;">Grid-Trading</summary>
                <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
                    <RadzenColumn Size="4">
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                            <RadzenCheckBox @bind-Value="_editGridEnabled" />
                            <RadzenLabel Text="Grid-Trading aktivieren" />
                        </RadzenStack>
                        <div class="hint" style="margin-top: 4px;">Automatische Grid-Orders bei Seitwaertsmaerkten</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Grid-Spacing (Pips)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="double" @bind-Value="_editGridSpacing" ShowUpDown="false" Min="1" Step="5" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Abstand zwischen Grid-Levels</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Lot pro Level" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="decimal" @bind-Value="_editGridLotSize" ShowUpDown="false" Min="0.01m" Step="0.01m" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Levels oberhalb" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="int" @bind-Value="_editGridLevelsAbove" ShowUpDown="false" Min="1" Max="20" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Sell-Levels ueber dem Center</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Levels unterhalb" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="int" @bind-Value="_editGridLevelsBelow" ShowUpDown="false" Min="1" Max="20" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Buy-Levels unter dem Center</div>
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. aktive Grids" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="int" @bind-Value="_editGridMaxActive" ShowUpDown="false" Min="1" Max="10" Style="width: 100%;" />
                    </RadzenColumn>
                    <RadzenColumn Size="4">
                        <RadzenLabel Text="Max. Levels pro Zyklus" Style="display: block; margin-bottom: 4px;" />
                        <RadzenNumeric TValue="int" @bind-Value="_editGridMaxPerCycle" ShowUpDown="false" Min="1" Max="10" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Schutz vor Gaps</div>
                    </RadzenColumn>
                </RadzenRow>
            </details>

            @* Schritt 6: Strategie / LLM-Prompt *@
            <details>
                <summary style="cursor: pointer; font-weight: 600; margin-bottom: 12px;">Strategie / LLM-Prompt</summary>
                <RadzenRow Gap="16px" Style="margin-bottom: 16px;">
                    <RadzenColumn Size="6">
                        <RadzenLabel Text="Strategie-Label" Style="display: block; margin-bottom: 4px;" />
                        <RadzenTextBox @bind-Value="_editStrategyLabel" Placeholder="z.B. Konservativ, Aggressiv" Style="width: 100%;" />
                        <div class="hint" style="margin-top: 4px;">Wird im Strategie-Vergleich angezeigt</div>
                    </RadzenColumn>
                    <RadzenColumn Size="12">
                        <RadzenLabel Text="Custom System-Prompt (optional)" Style="display: block; margin-bottom: 4px;" />
                        <RadzenTextArea @bind-Value="_editStrategyPrompt" Rows="6" Style="width: 100%;" Placeholder="Leer = Standard-Prompt. Hier eigene Trading-Strategie beschreiben die das LLM befolgen soll..." />
                        <div class="hint" style="margin-top: 4px;">Wird an den Standard-Prompt angehaengt. Beschreibt die Handelsstrategie, erlaubte Instrumente, Risikoverhalten etc.</div>
                    </RadzenColumn>
                    <RadzenColumn Size="12">
                        <details>
                            <summary style="cursor: pointer; font-size: 0.8rem; color: var(--muted);">Standard-Prompt anzeigen</summary>
                            <pre style="margin-top: 8px; padding: 12px; background: var(--bg); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-secondary); white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@ClaudePromptBuilder.DefaultSystemPrompt</pre>
                        </details>
                    </RadzenColumn>
                </RadzenRow>
            </details>

            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" Style="margin-top: 8px;">
                <RadzenButton Text="@(_editMode ? "Speichern" : "Account anlegen")" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" />
                <RadzenButton Text="Abbrechen" Variant="Variant.Outlined" Click="@HideForm" ButtonType="ButtonType.Button" />
            </RadzenStack>
        </EditForm>
    </RadzenCard>
}

@* ── Account-Karten ──────────────────────────────────────────────────── *@
@if (_accounts.Count == 0 && !_showForm)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" Shade="Shade.Dark" AllowClose="false">
        Noch keine Accounts vorhanden. Legen Sie oben einen neuen Account an um den Trading Bot zu starten.
    </RadzenAlert>
}

@foreach (var acc in _accounts)
{
    var liveCtx = AccountMgr.Accounts.FirstOrDefault(a => a.AccountId == acc.Id);
    var isConnected = liveCtx?.EffectiveBroker.IsConnected ?? false;
    var isRunning = liveCtx?.Engine.IsRunning ?? false;
    var isPaused = liveCtx?.Engine.IsPaused ?? false;

    <RadzenCard Style="margin-bottom: 12px; padding: 16px 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div style="display: flex; align-items: center; gap: 12px;">
                @{
                    var dotColor = isConnected ? "var(--green)" : liveCtx != null ? "var(--red)" : "var(--muted)";
                }
                <div style="width: 10px; height: 10px; border-radius: 50%; background: @dotColor;" title="@(isConnected ? "Verbunden" : "Getrennt")"></div>
                <div>
                    <strong style="font-size: 1.1rem;">@acc.DisplayName</strong>
                    <span style="color: var(--muted); margin-left: 8px; font-size: 0.85rem;">@acc.Id</span>
                </div>
            </div>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="6px" AlignItems="AlignItems.Center">
                @if (acc.PaperTrading.Enabled)
                {
                    <RadzenBadge Text="PAPER" BadgeStyle="BadgeStyle.Warning" />
                }
                @if (liveCtx != null)
                {
                    @if (isPaused)
                    {
                        <RadzenBadge Text="PAUSIERT" BadgeStyle="BadgeStyle.Danger" />
                    }
                    else if (isRunning)
                    {
                        <RadzenBadge Text="AKTIV" BadgeStyle="BadgeStyle.Success" />
                    }
                }
                <RadzenButton Text="Bearbeiten" Variant="Variant.Outlined" Size="ButtonSize.Small" Click="@(() => EditAccount(acc))" />
                @if (_accounts.Count > 1)
                {
                    <RadzenButton Text="Entfernen" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => ConfirmRemove(acc.Id))" />
                }
            </RadzenStack>
        </div>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px; font-size: 0.85rem; color: var(--muted);">
            <div>Server: <strong style="color: var(--text);">@acc.TradeLocker.Server</strong></div>
            <div>Email: <strong style="color: var(--text);">@acc.TradeLocker.Email</strong></div>
            <div>Broker-Account: <strong style="color: var(--text);">@(acc.TradeLocker.AccountId ?? "Auto")</strong></div>
            <div>Confidence: <strong style="color: var(--text);">@acc.RiskManagement.MinConfidence.ToString("P0")</strong></div>
        </div>
    </RadzenCard>
}

@* ── Loeschen-Bestaetigungsdialog ─────────────────────────────────────── *@
@if (_confirmRemoveId != null)
{
    <div style="position: fixed; inset: 0; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; z-index: 100;">
        <RadzenCard Style="max-width: 400px;">
            <h3 style="margin-top: 0;">Account entfernen?</h3>
            <p>Account <strong>@_confirmRemoveId</strong> wirklich entfernen? Die Engine wird sofort gestoppt.</p>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" JustifyContent="JustifyContent.End">
                <RadzenButton Text="Abbrechen" Variant="Variant.Outlined" Click="@(() => _confirmRemoveId = null)" />
                <RadzenButton Text="Entfernen" ButtonStyle="ButtonStyle.Danger" Click="@DoRemove" />
            </RadzenStack>
        </RadzenCard>
    </div>
}

@code {
    private List<AccountConfig> _accounts = new();
    private bool _saveSuccess;
    private List<string> _errors = new();
    private bool _showForm;
    private bool _editMode;
    private string? _confirmRemoveId;

    // Form-Felder
    private string _editId = string.Empty;
    private string? _editOriginalId; // Original-ID beim Bearbeiten (fuer Rename)
    private string _editDisplayName = string.Empty;
    private string _editBaseUrl = "https://demo.tradelocker.com/backend-api";
    private string _editServer = string.Empty;
    private string _editEmail = string.Empty;
    private string _editPassword = string.Empty;
    private string? _editAccountId;
    private bool _editPaperEnabled;
    private decimal _editPaperBalance = 25000m;
    private double _editMinConfidence = 0.65;
    private double _editMaxPosSize = 10.0;
    private int _editMaxOpenPos = 10;
    private double _editMaxDailyLossPercent = 3.0;
    private decimal _editMaxDailyLossAbsolute = 500m;
    private double _editStopLossPercent = 5.0;
    private int _editTradingInterval = 15;
    private double _editRiskPerTrade = 2.0;
    private double _editMaxSpreadPips = 0;
    private double _editMaxWeeklyLoss = 0;
    private double _editMaxMonthlyLoss = 0;
    private double _editMaxDrawdown = 0;
    private double _editMaxCorrelatedExposure = 0;
    private double _editTrailingStop = 0;
    private double _editBreakevenTrigger = 0;
    private double _editPartialClosePercent = 0;
    private double _editPartialCloseTrigger = 30;
    // Grid-Trading
    private bool _editGridEnabled;
    private double _editGridSpacing = 20;
    private decimal _editGridLotSize = 0.01m;
    private int _editGridLevelsAbove = 5;
    private int _editGridLevelsBelow = 5;
    private int _editGridMaxActive = 3;
    private int _editGridMaxPerCycle = 2;
    // Strategie
    private string _editStrategyPrompt = string.Empty;
    private string _editStrategyLabel = string.Empty;

    private record DropDownItem(string Text, string Value);
    private List<DropDownItem> _serverUrlOptions = new()
    {
        new("Demo (demo.tradelocker.com)", "https://demo.tradelocker.com/backend-api"),
        new("Live (live.tradelocker.com)", "https://live.tradelocker.com/backend-api")
    };

    protected override async Task OnInitializedAsync() => await LoadAccountsAsync();

    private async Task LoadAccountsAsync()
    {
        _accounts = await SettingsRepo.GetAllAccountsAsync();
    }

    private void ShowAddForm()
    {
        _editMode = false;
        _showForm = true;
        _saveSuccess = false;
        _errors.Clear();
        ResetFormFields();
    }

    private void HideForm()
    {
        _showForm = false;
        _editMode = false;
        _errors.Clear();
    }

    private void EditAccount(AccountConfig acc)
    {
        _editMode = true;
        _showForm = true;
        _saveSuccess = false;
        _errors.Clear();
        _editId = acc.Id;
        _editOriginalId = acc.Id;
        _editDisplayName = acc.DisplayName;
        _editBaseUrl = acc.TradeLocker.BaseUrl;
        _editServer = acc.TradeLocker.Server;
        _editEmail = acc.TradeLocker.Email;
        _editPassword = string.Empty; // Passwort nicht vorbelegen aus Sicherheitsgruenden
        _editAccountId = acc.TradeLocker.AccountId;
        _editPaperEnabled = acc.PaperTrading.Enabled;
        _editPaperBalance = acc.PaperTrading.InitialBalance;
        _editMinConfidence = acc.RiskManagement.MinConfidence;
        _editMaxPosSize = acc.RiskManagement.MaxPositionSizePercent;
        _editMaxOpenPos = acc.RiskManagement.MaxOpenPositions;
        _editMaxDailyLossPercent = acc.RiskManagement.MaxDailyLossPercent;
        _editMaxDailyLossAbsolute = acc.RiskManagement.MaxDailyLossAbsolute;
        _editStopLossPercent = acc.RiskManagement.StopLossPercent;
        _editTradingInterval = acc.RiskManagement.TradingIntervalMinutes;
        _editRiskPerTrade = acc.RiskManagement.RiskPerTradePercent;
        _editMaxSpreadPips = acc.RiskManagement.MaxSpreadPips;
        _editMaxWeeklyLoss = acc.RiskManagement.MaxWeeklyLossPercent;
