    private async Task SaveAccount()
    {
        _saveSuccess = false;
        _errors = new();

        var trimmedId = _editId?.Trim() ?? string.Empty;
        var isRenamed = _editMode && _editOriginalId != null
            && !trimmedId.Equals(_editOriginalId, StringComparison.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(trimmedId))
            _errors.Add("Kurzname (ID) ist erforderlich.");
        else if (trimmedId.Contains(' '))
            _errors.Add("Kurzname darf keine Leerzeichen enthalten.");
        else if ((!_editMode || isRenamed) && _accounts.Any(a => a.Id.Equals(trimmedId, StringComparison.OrdinalIgnoreCase)))
            _errors.Add($"Ein Account mit ID \"{trimmedId}\" existiert bereits.");
        if (string.IsNullOrWhiteSpace(_editEmail))
            _errors.Add("Email ist erforderlich.");
        if (string.IsNullOrWhiteSpace(_editServer))
            _errors.Add("Server-Name ist erforderlich.");
        if (!_editMode && string.IsNullOrWhiteSpace(_editPassword))
            _errors.Add("Passwort ist erforderlich.");

        if (_errors.Any()) return;

        var existingAccount = _editMode && _editOriginalId != null
            ? _accounts.FirstOrDefault(a => a.Id == _editOriginalId)
            : null;

        var acc = new AccountConfig
        {
            Id = trimmedId,
            DisplayName = string.IsNullOrWhiteSpace(_editDisplayName) ? trimmedId : _editDisplayName.Trim(),
            TradeLocker = new TradeLockerSettings
            {
                BaseUrl = _editBaseUrl.Trim(),
                Server = _editServer.Trim(),
                Email = _editEmail.Trim(),
                Password = string.IsNullOrEmpty(_editPassword) && existingAccount != null
                    ? existingAccount.TradeLocker.Password
                    : _editPassword,
                AccountId = string.IsNullOrWhiteSpace(_editAccountId) ? null : _editAccountId.Trim()
            },
            PaperTrading = new PaperTradingSettings
            {
                Enabled = _editPaperEnabled,
                InitialBalance = _editPaperBalance
            },
            RiskManagement = existingAccount?.RiskManagement ?? new RiskSettings()
        };
        acc.RiskManagement.MinConfidence = _editMinConfidence;
        acc.RiskManagement.MaxPositionSizePercent = _editMaxPosSize;
        acc.RiskManagement.MaxOpenPositions = _editMaxOpenPos;
        acc.RiskManagement.MaxDailyLossPercent = _editMaxDailyLossPercent;
        acc.RiskManagement.MaxDailyLossAbsolute = _editMaxDailyLossAbsolute;
        acc.RiskManagement.StopLossPercent = _editStopLossPercent;
        acc.RiskManagement.TradingIntervalMinutes = _editTradingInterval;
        acc.RiskManagement.RiskPerTradePercent = _editRiskPerTrade;
        acc.RiskManagement.MaxSpreadPips = _editMaxSpreadPips;
        acc.RiskManagement.MaxWeeklyLossPercent = _editMaxWeeklyLoss;
        acc.RiskManagement.MaxMonthlyLossPercent = _editMaxMonthlyLoss;
        acc.RiskManagement.MaxDrawdownPercent = _editMaxDrawdown;
        acc.RiskManagement.MaxCorrelatedExposurePercent = _editMaxCorrelatedExposure;
        acc.RiskManagement.TrailingStopPips = _editTrailingStop;
        acc.RiskManagement.BreakevenTriggerPips = _editBreakevenTrigger;
        acc.RiskManagement.PartialClosePercent = _editPartialClosePercent;
        acc.RiskManagement.PartialCloseTriggerPips = _editPartialCloseTrigger;
        acc.RiskManagement.Grid.Enabled = _editGridEnabled;
        acc.RiskManagement.Grid.GridSpacingPips = _editGridSpacing;
        acc.RiskManagement.Grid.LotSizePerLevel = _editGridLotSize;
        acc.RiskManagement.Grid.GridLevelsAbove = _editGridLevelsAbove;
        acc.RiskManagement.Grid.GridLevelsBelow = _editGridLevelsBelow;
        acc.RiskManagement.Grid.MaxActiveGrids = _editGridMaxActive;
        acc.RiskManagement.Grid.MaxLevelsPerCycle = _editGridMaxPerCycle;
        acc.StrategyPrompt = _editStrategyPrompt;
        acc.StrategyLabel = _editStrategyLabel;

        try
        {
            // Bei Rename: alte Engine stoppen + ID loeschen, neue speichern + starten
            if (isRenamed && _editOriginalId != null)
            {
                await AccountMgr.RemoveAccountAsync(_editOriginalId);
                await SettingsRepo.DeleteAccountAsync(_editOriginalId);
            }

            await SettingsRepo.SaveAccountAsync(acc);

            if (_editMode && !isRenamed)
            {
                // Hot-Reload fuer bestehende Accounts
                await AccountMgr.ReloadAccountSettingsAsync(acc.Id);
            }
            else
            {
                // Neuer Account (oder umbenannt): Engine zur Laufzeit starten
                await AccountMgr.AddAccountAsync(acc);
            }

            _saveSuccess = true;
            HideForm();
            await LoadAccountsAsync();
        }
        catch (Exception ex)
        {
            _errors.Add($"Fehler beim Speichern: {ex.Message}");
        }
    }

    private void ConfirmRemove(string id) => _confirmRemoveId = id;

    private async Task DoRemove()
    {
        if (_confirmRemoveId != null)
        {
            await AccountMgr.RemoveAccountAsync(_confirmRemoveId);
            await SettingsRepo.DeleteAccountAsync(_confirmRemoveId);
            _saveSuccess = true;
            _confirmRemoveId = null;
            await LoadAccountsAsync();
        }
    }
