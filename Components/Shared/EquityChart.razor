@inject IJSRuntime JS

<div class="section">
    <h2>Equity-Kurve</h2>
    @if (PnLHistory.Any())
    {
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px;">
            <canvas id="equityChart" style="width:100%;height:300px;"></canvas>
        </div>
    }
    else
    {
        <div class="empty-state">Noch keine PnL-Daten vorhanden</div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public List<DailyPnL> PnLHistory { get; set; } = new();

    private string _lastRenderedData = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!PnLHistory.Any())
            return;

        var sorted = PnLHistory.OrderBy(p => p.Date).ToList();
        var dataKey = string.Join(",", sorted.Select(p => $"{p.Date}:{p.PortfolioValue}"));

        // Nur rendern wenn sich Daten geaendert haben
        if (dataKey == _lastRenderedData)
            return;
        _lastRenderedData = dataKey;

        var labels = sorted.Select(p => p.Date.ToString("dd.MM")).ToArray();
        var values = sorted.Select(p => (double)p.PortfolioValue).ToArray();

        // Drawdown-Linie berechnen
        double peak = 0;
        var drawdownValues = new double[sorted.Count];
        for (int i = 0; i < sorted.Count; i++)
        {
            var val = (double)sorted[i].PortfolioValue;
            if (val > peak) peak = val;
            drawdownValues[i] = peak > 0 ? (val - peak) : 0;
        }

        try
        {
            await JS.InvokeVoidAsync("renderEquityChart", labels, values, drawdownValues);
        }
        catch
        {
            // JS Interop kann fehlschlagen bei Disconnect
        }
    }
}
